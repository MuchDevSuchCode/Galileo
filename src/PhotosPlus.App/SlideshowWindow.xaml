<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="PhotosPlus.SlideshowWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid x:Name="Root" Background="Black" KeyDown="Root_KeyDown" PointerMoved="Root_PointerMoved">

        <!-- Two layered images for crossfade -->
        <Image x:Name="ImageA" Stretch="Uniform" Opacity="1" RenderTransformOrigin="0.5,0.5">
            <Image.RenderTransform>
                <CompositeTransform x:Name="TransformA" />
            </Image.RenderTransform>
        </Image>
        <Image x:Name="ImageB" Stretch="Uniform" Opacity="0" RenderTransformOrigin="0.5,0.5">
            <Image.RenderTransform>
                <CompositeTransform x:Name="TransformB" />
            </Image.RenderTransform>
        </Image>

        <!-- Caption -->
        <Border x:Name="CaptionBar" VerticalAlignment="Bottom" HorizontalAlignment="Center"
                Background="#88000000" CornerRadius="6" Padding="14,6" Margin="0,0,0,80">
            <TextBlock x:Name="Caption" Foreground="White" FontSize="14" />
        </Border>

        <!-- Auto-hiding controls -->
        <Border x:Name="Controls" VerticalAlignment="Bottom" HorizontalAlignment="Center"
                Background="#AA000000" CornerRadius="28" Padding="10,6" Margin="0,0,0,24">
            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                <Button x:Name="PrevBtn" Click="Prev_Click" Width="44" Height="44" CornerRadius="22" Background="Transparent">
                    <FontIcon Glyph="&#xE892;" FontFamily="Segoe Fluent Icons" Foreground="White" />
                </Button>
                <Button x:Name="PlayBtn" Click="PlayPause_Click" Width="44" Height="44" CornerRadius="22" Background="Transparent">
                    <FontIcon x:Name="PlayIcon" Glyph="&#xE769;" FontFamily="Segoe Fluent Icons" Foreground="White" />
                </Button>
                <Button x:Name="NextBtn" Click="Next_Click" Width="44" Height="44" CornerRadius="22" Background="Transparent">
                    <FontIcon Glyph="&#xE893;" FontFamily="Segoe Fluent Icons" Foreground="White" />
                </Button>
                <AppBarSeparator Foreground="#55FFFFFF" />
                <Button x:Name="LessTimeBtn" Click="Faster_Click" Width="44" Height="44" CornerRadius="22" Background="Transparent"
                        ToolTipService.ToolTip="Less time per photo">
                    <FontIcon Glyph="&#xE738;" FontFamily="Segoe Fluent Icons" Foreground="White" />
                </Button>
                <TextBlock x:Name="SpeedText" Foreground="White" VerticalAlignment="Center" MinWidth="36"
                           TextAlignment="Center" />
                <Button x:Name="MoreTimeBtn" Click="Slower_Click" Width="44" Height="44" CornerRadius="22" Background="Transparent"
                        ToolTipService.ToolTip="More time per photo">
                    <FontIcon Glyph="&#xE710;" FontFamily="Segoe Fluent Icons" Foreground="White" />
                </Button>
                <ToggleButton x:Name="ShuffleBtn" Click="Shuffle_Click" Width="44" Height="44" CornerRadius="22" Background="Transparent"
                              ToolTipService.ToolTip="Shuffle">
                    <FontIcon Glyph="&#xE8B1;" FontFamily="Segoe Fluent Icons" Foreground="White" />
                </ToggleButton>
                <AppBarSeparator Foreground="#55FFFFFF" />
                <Button x:Name="ExitBtn" Click="Exit_Click" Width="44" Height="44" CornerRadius="22" Background="Transparent"
                        ToolTipService.ToolTip="Exit (Esc)">
                    <FontIcon Glyph="&#xE711;" FontFamily="Segoe Fluent Icons" Foreground="White" />
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>
