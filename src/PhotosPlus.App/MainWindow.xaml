<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="PhotosPlus.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid x:Name="RootGrid" KeyDown="RootGrid_KeyDown"
          AllowDrop="True" DragOver="RootGrid_DragOver" Drop="RootGrid_Drop">

        <!-- ===================== File Explorer (home) ===================== -->
        <Grid x:Name="ExplorerView">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Grid Grid.Column="0" Background="{ThemeResource LayerFillColorAltBrush}"
                  BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,1,0">
                <ScrollViewer Padding="8,48,8,12">
                    <StackPanel Spacing="2">
                        <Button Click="NavHome_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                Background="Transparent" BorderThickness="0" Padding="10,8">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE80F;" FontFamily="Segoe MDL2 Assets" FontSize="16" />
                                <TextBlock Text="Home (This PC)" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <TextBlock Text="Quick access" Opacity="0.6" FontSize="12" Margin="10,12,0,4" />
                        <ListView x:Name="QuickAccessList" SelectionMode="None" IsItemClickEnabled="True"
                                  ItemClick="Sidebar_ItemClick">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="10" Height="32">
                                        <Image Source="{Binding Icon}" Width="18" Height="18" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <TextBlock Text="This PC" Opacity="0.6" FontSize="12" Margin="10,12,0,4" />
                        <ListView x:Name="DrivesList" SelectionMode="None" IsItemClickEnabled="True"
                                  ItemClick="Sidebar_ItemClick">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="10" Height="32">
                                        <Image Source="{Binding Icon}" Width="18" Height="18" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- Content (offset below the 40px title-bar drag region so the nav buttons are clickable) -->
            <Grid Grid.Column="1" Margin="0,40,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="48" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Nav + address -->
                <Grid Grid.Row="0" Margin="8,0" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                        <Button x:Name="BackNav" Style="{StaticResource GlyphButton}" Width="36" Height="36" Click="NavBack_Click" ToolTipService.ToolTip="Back">
                            <FontIcon Glyph="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="14" />
                        </Button>
                        <Button x:Name="FwdNav" Style="{StaticResource GlyphButton}" Width="36" Height="36" Click="NavForward_Click" ToolTipService.ToolTip="Forward">
                            <FontIcon Glyph="&#xE72A;" FontFamily="Segoe MDL2 Assets" FontSize="14" />
                        </Button>
                        <Button x:Name="UpNav" Style="{StaticResource GlyphButton}" Width="36" Height="36" Click="NavUp_Click" ToolTipService.ToolTip="Up">
                            <FontIcon Glyph="&#xE70E;" FontFamily="Segoe MDL2 Assets" FontSize="14" />
                        </Button>
                    </StackPanel>

                    <Border Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="6"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                            Margin="6,0,2,0" Padding="8,0" Height="34" VerticalAlignment="Center"
                            HorizontalAlignment="Stretch" DoubleTapped="PathBar_DoubleTapped">
                        <Grid>
                            <ScrollViewer x:Name="BreadcrumbScroller" HorizontalScrollMode="Auto"
                                          HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled">
                                <StackPanel x:Name="Breadcrumb" Orientation="Horizontal" VerticalAlignment="Center" />
                            </ScrollViewer>
                            <TextBox x:Name="AddressBox" Visibility="Collapsed" BorderThickness="0"
                                     Background="Transparent" VerticalAlignment="Center" KeyDown="AddressBox_KeyDown" />
                        </Grid>
                    </Border>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                        <Button x:Name="EditPathBtn" Style="{StaticResource GlyphButton}" Width="36" Height="36" Click="EditPath_Click" ToolTipService.ToolTip="Edit path">
                            <FontIcon Glyph="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="14" />
                        </Button>
                        <Button x:Name="RefreshBtn" Style="{StaticResource GlyphButton}" Width="36" Height="36" Click="Refresh_Click" ToolTipService.ToolTip="Refresh">
                            <FontIcon Glyph="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="14" />
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Command strip -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="4" Margin="10,4,10,8" VerticalAlignment="Center">
                    <Button Click="NewFolder_Click" ToolTipService.ToolTip="New folder">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE8F4;" FontFamily="Segoe MDL2 Assets" FontSize="14" />
                            <TextBlock Text="New folder" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="HideFolderBtn" Click="HideFolder_Click" ToolTipService.ToolTip="Hide this folder (appears empty)">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon x:Name="HideFolderIcon" Glyph="&#xED1A;" FontFamily="Segoe MDL2 Assets" FontSize="14" />
                            <TextBlock x:Name="HideFolderText" Text="Hide folder" />
                        </StackPanel>
                    </Button>
                    <AppBarSeparator />
                    <Button Click="ExplorerSlideshow_Click" ToolTipService.ToolTip="Slideshow of this folder's images">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE786;" FontFamily="Segoe MDL2 Assets" FontSize="14" />
                            <TextBlock Text="Slideshow" />
                        </StackPanel>
                    </Button>
                    <Button Click="ExplorerCollage_Click" ToolTipService.ToolTip="Collage of this folder's images">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE8A9;" FontFamily="Segoe MDL2 Assets" FontSize="14" />
                            <TextBlock Text="Collage" />
                        </StackPanel>
                    </Button>

                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Click="Settings_Click" ToolTipService.ToolTip="Settings">
                            <FontIcon Glyph="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="14" />
                        </Button>
                        <ToggleButton x:Name="ShowHiddenToggle" Click="ShowAppHidden_Click" ToolTipService.ToolTip="Show app-hidden folders">
                            <FontIcon Glyph="&#xE890;" FontFamily="Segoe MDL2 Assets" FontSize="14" />
                        </ToggleButton>
                        <Button x:Name="ViewModeBtn" ToolTipService.ToolTip="View">
                            <FontIcon Glyph="&#xE8A9;" FontFamily="Segoe MDL2 Assets" FontSize="14" />
                            <Button.Flyout>
                                <MenuFlyout>
                                    <RadioMenuFlyoutItem Text="Large icons" GroupName="view" IsChecked="True" Click="ViewMode_Click" Tag="Large" />
                                    <RadioMenuFlyoutItem Text="Medium icons" GroupName="view" Click="ViewMode_Click" Tag="Medium" />
                                    <RadioMenuFlyoutItem Text="Small icons" GroupName="view" Click="ViewMode_Click" Tag="Small" />
                                    <RadioMenuFlyoutItem Text="Details" GroupName="view" Click="ViewMode_Click" Tag="Details" />
                                </MenuFlyout>
                            </Button.Flyout>
                        </Button>
                        <Slider x:Name="IconSizeSlider" Width="120" Minimum="48" Maximum="240" Value="110"
                                ValueChanged="IconSize_ValueChanged" VerticalAlignment="Center"
                                ToolTipService.ToolTip="Icon size" />
                    </StackPanel>
                </StackPanel>

                <!-- Content area -->
                <Grid Grid.Row="2">
                    <GridView x:Name="ExplorerIconsView" Padding="12,0,12,12"
                              SelectionMode="Extended"
                              IsItemClickEnabled="True"
                              CanDragItems="True"
                              ItemClick="ExplorerItem_Click"
                              DoubleTapped="ExplorerItem_DoubleTapped"
                              DragItemsStarting="Explorer_DragItemsStarting"
                              RightTapped="ExplorerView_RightTapped"
                              ContainerContentChanging="ExplorerIcons_ContainerContentChanging">
                        <GridView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <ItemsWrapGrid Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </GridView.ItemsPanel>
                    </GridView>

                    <Grid x:Name="ExplorerDetailsView" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid Margin="58,0,24,0" Height="28" Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="90" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Name" Opacity="0.6" FontSize="12" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="Date modified" Opacity="0.6" FontSize="12" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2" Text="Type" Opacity="0.6" FontSize="12" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="3" Text="Size" Opacity="0.6" FontSize="12" VerticalAlignment="Center" TextAlignment="Right" />
                        </Grid>
                        <ListView x:Name="ExplorerDetailsList" Grid.Row="1" Padding="12,0,12,12"
                                  SelectionMode="Extended"
                                  IsItemClickEnabled="True"
                                  CanDragItems="True"
                                  ItemClick="ExplorerItem_Click"
                                  DoubleTapped="ExplorerItem_DoubleTapped"
                                  DragItemsStarting="Explorer_DragItemsStarting"
                                  RightTapped="ExplorerView_RightTapped"
                                  ContainerContentChanging="ExplorerIcons_ContainerContentChanging"
                                  ItemTemplate="{StaticResource ExplorerDetailsTemplate}" />
                    </Grid>

                    <!-- Hidden-folder placeholder -->
                    <StackPanel x:Name="HiddenFolderPlaceholder" Visibility="Collapsed"
                                HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                        <FontIcon Glyph="&#xED1A;" FontFamily="Segoe MDL2 Assets" FontSize="48" Opacity="0.6" />
                        <TextBlock Text="This folder is hidden" FontSize="18" HorizontalAlignment="Center" />
                        <TextBlock Text="Its contents are concealed in PhotosPlus." Opacity="0.7" HorizontalAlignment="Center" />
                        <Button Content="Unhide this folder" Click="UnhideCurrent_Click" HorizontalAlignment="Center" />
                    </StackPanel>

                    <TextBlock x:Name="ExplorerEmpty" Text="This folder is empty" Visibility="Collapsed"
                               Opacity="0.6" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Grid>
            </Grid>
        </Grid>

        <!-- ===================== Gallery ===================== -->
        <Grid x:Name="GalleryView" Visibility="Collapsed">
            <GridView x:Name="PhotoGrid"
                      Padding="24,56,24,32"
                      SelectionMode="None"
                      IsItemClickEnabled="True"
                      ItemClick="PhotoGrid_ItemClick"
                      SelectionChanged="PhotoGrid_SelectionChanged"
                      RightTapped="PhotoGrid_RightTapped"
                      ContainerContentChanging="PhotoGrid_ContainerContentChanging">
                <GridView.ItemTemplate>
                    <DataTemplate>
                        <Grid Width="196" Height="196" Margin="5"
                              CornerRadius="10" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                            <Image Source="{Binding Thumbnail}" Stretch="UniformToFill" />
                            <Border Background="#B0000000" VerticalAlignment="Bottom" Padding="8,4">
                                <TextBlock Text="{Binding FileName}" FontSize="11"
                                           TextTrimming="CharacterEllipsis" Foreground="White" />
                            </Border>
                            <FontIcon Glyph="&#xE735;" FontFamily="Segoe MDL2 Assets"
                                      Foreground="Gold" FontSize="16"
                                      HorizontalAlignment="Right" VerticalAlignment="Top" Margin="10"
                                      Visibility="{Binding FavoriteVisibility}" />
                            <Border Background="#CC000000" CornerRadius="10"
                                    Visibility="{Binding HiddenVisibility}">
                                <FontIcon Glyph="&#xED1A;" FontFamily="Segoe MDL2 Assets"
                                          Foreground="White" FontSize="28"
                                          HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </Grid>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>

            <!-- Empty state -->
            <StackPanel x:Name="EmptyState" Visibility="Visible"
                        HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="14" MaxWidth="420">
                <FontIcon Glyph="&#xEB9F;" FontFamily="Segoe MDL2 Assets" FontSize="56" Opacity="0.45" />
                <TextBlock Text="Your photos, beautifully" FontSize="24" FontWeight="SemiBold" HorizontalAlignment="Center" />
                <TextBlock Text="Open a file or folder, or drag photos anywhere onto this window."
                           Opacity="0.7" FontSize="14" TextWrapping="Wrap" TextAlignment="Center" />
                <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center" Margin="0,4,0,0">
                    <Button Content="Open file" Click="OpenFile_Click" Style="{StaticResource AccentButtonStyle}" />
                    <Button Content="Open folder" Click="OpenFolder_Click" />
                </StackPanel>
            </StackPanel>

            <!-- Floating gallery toolbar -->
            <Border HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,48,16,0"
                    CornerRadius="24" Padding="4" Background="{ThemeResource AcrylicInAppFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Orientation="Horizontal" Spacing="2">
                    <Button x:Name="OpenButton" Style="{StaticResource GlyphButton}"
                            ToolTipService.ToolTip="Open">
                        <FontIcon Glyph="&#xE8E5;" FontFamily="Segoe MDL2 Assets" />
                        <Button.Flyout>
                            <MenuFlyout>
                                <MenuFlyoutItem Text="Open file…" Click="OpenFile_Click">
                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8E5;" FontFamily="Segoe MDL2 Assets" /></MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem Text="Open folder…" Click="OpenFolder_Click">
                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE838;" FontFamily="Segoe MDL2 Assets" /></MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>
                    <Button Style="{StaticResource GlyphButton}" Click="Slideshow_Click"
                            ToolTipService.ToolTip="Slideshow (F5)">
                        <FontIcon Glyph="&#xE786;" FontFamily="Segoe MDL2 Assets" />
                    </Button>
                    <Button Style="{StaticResource GlyphButton}" Click="Collage_Click"
                            ToolTipService.ToolTip="Collage">
                        <FontIcon Glyph="&#xE8A9;" FontFamily="Segoe MDL2 Assets" />
                    </Button>
                    <Button Style="{StaticResource GlyphButton}" Click="Settings_Click"
                            ToolTipService.ToolTip="Settings">
                        <FontIcon Glyph="&#xE713;" FontFamily="Segoe MDL2 Assets" />
                    </Button>
                    <Button Style="{StaticResource GlyphButton}" ToolTipService.ToolTip="More">
                        <FontIcon Glyph="&#xE712;" FontFamily="Segoe MDL2 Assets" />
                        <Button.Flyout>
                            <MenuFlyout>
                                <ToggleMenuFlyoutItem x:Name="SelectModeButton" Text="Select photos" Click="SelectMode_Click" />
                                <ToggleMenuFlyoutItem x:Name="HiddenAlbumButton" Text="Show Hidden album" Click="HiddenAlbum_Click" />
                                <ToggleMenuFlyoutItem x:Name="FavoritesFilterButton" Text="Favorites only" Click="FavoritesFilter_Click" />
                                <MenuFlyoutSeparator />
                                <MenuFlyoutItem Text="Close gallery" Click="CloseGallery_Click">
                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8BB;" FontFamily="Segoe MDL2 Assets" /></MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ===================== Viewer ===================== -->
        <Grid x:Name="ViewerView" Visibility="Collapsed" Background="#FF101013"
              PointerMoved="ViewerView_PointerMoved">

            <Grid x:Name="ImageHost" Background="Transparent"
                  SizeChanged="ImageHost_SizeChanged"
                  PointerWheelChanged="ImageHost_PointerWheelChanged"
                  PointerPressed="ImageHost_PointerPressed"
                  PointerMoved="ImageHost_PointerMoved"
                  PointerReleased="ImageHost_PointerReleased"
                  DoubleTapped="ImageHost_DoubleTapped"
                  RightTapped="ImageHost_RightTapped">
                <Image x:Name="ViewerImage" Stretch="Uniform"
                       HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                       RenderTransformOrigin="0.5,0.5"
                       ImageOpened="ViewerImage_ImageOpened"
                       ImageFailed="ViewerImage_ImageFailed">
                    <Image.RenderTransform>
                        <CompositeTransform x:Name="ViewerTransform" />
                    </Image.RenderTransform>
                </Image>
            </Grid>

            <!-- Embedded video player (shown for video files) -->
            <MediaPlayerElement x:Name="VideoPlayer" Visibility="Collapsed"
                                AreTransportControlsEnabled="True" AutoPlay="True" Stretch="Uniform" />
            <Border x:Name="VideoBackBar" Visibility="Collapsed"
                    HorizontalAlignment="Left" VerticalAlignment="Top" Margin="16,48,0,0"
                    CornerRadius="22" Padding="4" Background="{StaticResource PillBrush}">
                <Button Style="{StaticResource GlyphButton}" Foreground="White" Click="BackToGallery_Click"
                        ToolTipService.ToolTip="Back (Esc)">
                    <FontIcon Glyph="&#xE72B;" FontFamily="Segoe MDL2 Assets" />
                </Button>
            </Border>

            <!-- Eye obscure: plain black curtain -->
            <Grid x:Name="ObscureOverlay" Visibility="Collapsed" Background="Black" />

            <!-- Floating chrome that auto-hides -->
            <Grid x:Name="ViewerChrome">

                <!-- Top-left: back -->
                <Border HorizontalAlignment="Left" VerticalAlignment="Top" Margin="16,48,0,0"
                        CornerRadius="22" Padding="4" Background="{StaticResource PillBrush}">
                    <Button Style="{StaticResource GlyphButton}" Foreground="White" Click="BackToGallery_Click"
                            ToolTipService.ToolTip="Back to gallery (Esc)">
                        <FontIcon Glyph="&#xE72B;" FontFamily="Segoe MDL2 Assets" />
                    </Button>
                </Border>

                <!-- Top-right: actions -->
                <Border HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,48,16,0"
                        CornerRadius="24" Padding="4" Background="{StaticResource PillBrush}">
                    <StackPanel Orientation="Horizontal" Spacing="2">
                        <Button x:Name="FavoriteButton" Style="{StaticResource GlyphButton}" Foreground="White"
                                Click="Favorite_Click" ToolTipService.ToolTip="Favorite">
                            <FontIcon x:Name="FavoriteIcon" Glyph="&#xE734;" FontFamily="Segoe MDL2 Assets" />
                        </Button>
                        <Button x:Name="EyeButton" Style="{StaticResource GlyphButton}" Foreground="White"
                                Click="Eye_Click" ToolTipService.ToolTip="Hide / reveal (H)">
                            <FontIcon x:Name="EyeIcon" Glyph="&#xE890;" FontFamily="Segoe MDL2 Assets" />
                            <Button.Flyout>
                                <MenuFlyout Placement="Bottom">
                                    <MenuFlyoutItem Text="Hide / reveal in view (H)" Click="EyeObscure_Click">
                                        <MenuFlyoutItem.Icon><FontIcon Glyph="&#xED1A;" FontFamily="Segoe MDL2 Assets" /></MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutItem Text="Hide permanently (Hidden album)" Click="EyeHidePermanent_Click">
                                        <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE890;" FontFamily="Segoe MDL2 Assets" /></MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                </MenuFlyout>
                            </Button.Flyout>
                        </Button>
                        <Button Style="{StaticResource GlyphButton}" Foreground="White" Click="Rotate_Click"
                                ToolTipService.ToolTip="Rotate (R)">
                            <FontIcon Glyph="&#xE7AD;" FontFamily="Segoe MDL2 Assets" />
                        </Button>
                        <Button Style="{StaticResource GlyphButton}" Foreground="White" Click="Info_Click"
                                ToolTipService.ToolTip="Photo info">
                            <FontIcon Glyph="&#xE946;" FontFamily="Segoe MDL2 Assets" />
                        </Button>
                        <Button Style="{StaticResource GlyphButton}" Foreground="White" Click="Reveal_Click"
                                ToolTipService.ToolTip="Reveal in Explorer">
                            <FontIcon Glyph="&#xEC50;" FontFamily="Segoe MDL2 Assets" />
                        </Button>
                        <Button Style="{StaticResource GlyphButton}" Foreground="White" Click="Delete_Click"
                                ToolTipService.ToolTip="Delete">
                            <FontIcon Glyph="&#xE74D;" FontFamily="Segoe MDL2 Assets" />
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Bottom-centre: navigation & zoom -->
                <Border HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,28"
                        CornerRadius="26" Padding="6" Background="{StaticResource PillBrush}">
                    <StackPanel Orientation="Horizontal" Spacing="2">
                        <Button Style="{StaticResource GlyphButton}" Foreground="White" Click="Prev_Click"
                                ToolTipService.ToolTip="Previous">
                            <FontIcon Glyph="&#xE76B;" FontFamily="Segoe MDL2 Assets" />
                        </Button>
                        <Button Style="{StaticResource GlyphButton}" Foreground="White" Click="ZoomOut_Click"
                                ToolTipService.ToolTip="Zoom out">
                            <FontIcon Glyph="&#xE71F;" FontFamily="Segoe MDL2 Assets" />
                        </Button>
                        <Button Style="{StaticResource GlyphButton}" Foreground="White" Click="Fit_Click"
                                ToolTipService.ToolTip="Fit (0)">
                            <FontIcon Glyph="&#xE9A6;" FontFamily="Segoe MDL2 Assets" />
                        </Button>
                        <Button Style="{StaticResource GlyphButton}" Foreground="White" Click="ZoomIn_Click"
                                ToolTipService.ToolTip="Zoom in">
                            <FontIcon Glyph="&#xE8A3;" FontFamily="Segoe MDL2 Assets" />
                        </Button>
                        <Button Style="{StaticResource GlyphButton}" Foreground="White" Click="Next_Click"
                                ToolTipService.ToolTip="Next">
                            <FontIcon Glyph="&#xE76C;" FontFamily="Segoe MDL2 Assets" />
                        </Button>
                        <Border Width="1" Margin="6,8" Background="#33FFFFFF" />
                        <Button Style="{StaticResource GlyphButton}" Foreground="White" Click="Slideshow_Click"
                                ToolTipService.ToolTip="Slideshow (F5)">
                            <FontIcon Glyph="&#xE786;" FontFamily="Segoe MDL2 Assets" />
                        </Button>
                        <Button Style="{StaticResource GlyphButton}" Foreground="White" Click="FullScreen_Click"
                                ToolTipService.ToolTip="Full screen (F11)">
                            <FontIcon Glyph="&#xE740;" FontFamily="Segoe MDL2 Assets" />
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Metadata panel -->
            <Border x:Name="InfoPanel" Visibility="Collapsed"
                    HorizontalAlignment="Right" VerticalAlignment="Top" Margin="16,104,16,0"
                    Width="330" Padding="18" CornerRadius="12"
                    Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="6">
                    <TextBlock Text="Photo info" FontWeight="SemiBold" FontSize="16" />
                    <TextBlock x:Name="InfoText" TextWrapping="Wrap" FontSize="13" Opacity="0.9" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- ===================== Collage ===================== -->
        <Grid x:Name="CollageView" Visibility="Collapsed" Background="#FF101013">
            <Canvas x:Name="CollageCanvas" SizeChanged="CollageCanvas_SizeChanged" />

            <!-- Floating collage controls -->
            <Border HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,28"
                    CornerRadius="26" Padding="6" Background="{StaticResource PillBrush}">
                <StackPanel Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                    <Button Style="{StaticResource GlyphButton}" Foreground="White" Click="CollageBack_Click"
                            ToolTipService.ToolTip="Back to gallery (Esc)">
                        <FontIcon Glyph="&#xE72B;" FontFamily="Segoe MDL2 Assets" />
                    </Button>
                    <Border Width="1" Margin="6,8" Background="#33FFFFFF" />
                    <Button Style="{StaticResource GlyphButton}" Foreground="White" Click="CollageFewer_Click"
                            ToolTipService.ToolTip="Fewer photos">
                        <FontIcon Glyph="&#xE738;" FontFamily="Segoe MDL2 Assets" />
                    </Button>
                    <TextBlock x:Name="CollageCountText" Foreground="White" VerticalAlignment="Center"
                               MinWidth="64" TextAlignment="Center" Text="0 photos" />
                    <Button Style="{StaticResource GlyphButton}" Foreground="White" Click="CollageMore_Click"
                            ToolTipService.ToolTip="More photos">
                        <FontIcon Glyph="&#xE710;" FontFamily="Segoe MDL2 Assets" />
                    </Button>
                    <Border Width="1" Margin="6,8" Background="#33FFFFFF" />
                    <Button Style="{StaticResource GlyphButton}" Foreground="White" ToolTipService.ToolTip="Layout">
                        <FontIcon Glyph="&#xE71D;" FontFamily="Segoe MDL2 Assets" />
                        <Button.Flyout>
                            <MenuFlyout>
                                <RadioMenuFlyoutItem x:Name="PresetJustified" Text="Justified" GroupName="preset"
                                                     IsChecked="True" Click="CollagePreset_Click" Tag="Justified" />
                                <RadioMenuFlyoutItem x:Name="PresetGrid" Text="Grid" GroupName="preset"
                                                     Click="CollagePreset_Click" Tag="Grid" />
                                <RadioMenuFlyoutItem x:Name="PresetHero" Text="Hero" GroupName="preset"
                                                     Click="CollagePreset_Click" Tag="Hero" />
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>
                    <Button Style="{StaticResource GlyphButton}" Foreground="White" Click="CollageShuffle_Click"
                            ToolTipService.ToolTip="Shuffle">
                        <FontIcon Glyph="&#xE8B1;" FontFamily="Segoe MDL2 Assets" />
                    </Button>
                    <Button Style="{StaticResource GlyphButton}" Foreground="White" Click="CollageSave_Click"
                            ToolTipService.ToolTip="Save collage…">
                        <FontIcon Glyph="&#xE74E;" FontFamily="Segoe MDL2 Assets" />
                    </Button>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ===================== Settings overlay ===================== -->
        <Grid x:Name="SettingsOverlay" Visibility="Collapsed" Background="#88000000"
              Tapped="SettingsScrim_Tapped">
            <Border Width="420" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Background="{ThemeResource LayerFillColorAltBrush}" CornerRadius="14"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    Padding="24" Tapped="SettingsCard_Tapped">
                <StackPanel Spacing="18">
                    <Grid>
                        <TextBlock Text="Settings" FontSize="22" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <Button Style="{StaticResource GlyphButton}" Click="SettingsClose_Click"
                                HorizontalAlignment="Right" ToolTipService.ToolTip="Close">
                            <FontIcon Glyph="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="14" />
                        </Button>
                    </Grid>

                    <TextBlock Text="General" FontWeight="SemiBold" Opacity="0.8" />
                    <Grid>
                        <TextBlock Text="Theme" VerticalAlignment="Center" />
                        <ComboBox x:Name="ThemeCombo" HorizontalAlignment="Right" MinWidth="160"
                                  SelectionChanged="ThemeCombo_SelectionChanged">
                            <ComboBoxItem Content="System default" />
                            <ComboBoxItem Content="Light" />
                            <ComboBoxItem Content="Dark" />
                        </ComboBox>
                    </Grid>
                    <Grid>
                        <TextBlock Text="Open items with" VerticalAlignment="Center" />
                        <ComboBox x:Name="OpenModeCombo" HorizontalAlignment="Right" MinWidth="160"
                                  SelectionChanged="OpenModeCombo_SelectionChanged">
                            <ComboBoxItem Content="Double-click" />
                            <ComboBoxItem Content="Single-click" />
                        </ComboBox>
                    </Grid>

                    <TextBlock Text="Slideshow" FontWeight="SemiBold" Opacity="0.8" Margin="0,6,0,0" />

                    <Grid>
                        <TextBlock Text="Seconds per photo" VerticalAlignment="Center" />
                        <TextBlock x:Name="SlideshowSecondsValue" Text="4s" HorizontalAlignment="Right" VerticalAlignment="Center" Opacity="0.8" />
                    </Grid>
                    <Slider x:Name="SlideshowSecondsSlider" Minimum="2" Maximum="30" StepFrequency="1"
                            ValueChanged="SlideshowSecondsSlider_ValueChanged" />

                    <Grid>
                        <TextBlock Text="Shuffle" VerticalAlignment="Center" />
                        <ToggleSwitch x:Name="ShuffleSwitch" HorizontalAlignment="Right" Toggled="ShuffleSwitch_Toggled" />
                    </Grid>
                    <Grid>
                        <TextBlock Text="Loop" VerticalAlignment="Center" />
                        <ToggleSwitch x:Name="LoopSwitch" HorizontalAlignment="Right" Toggled="LoopSwitch_Toggled" />
                    </Grid>
                    <Grid>
                        <TextBlock Text="Transition" VerticalAlignment="Center" />
                        <ComboBox x:Name="TransitionCombo" HorizontalAlignment="Right" MinWidth="160"
                                  SelectionChanged="TransitionCombo_SelectionChanged">
                            <ComboBoxItem Content="None" />
                            <ComboBoxItem Content="Crossfade" />
                            <ComboBoxItem Content="Ken Burns" />
                        </ComboBox>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ===================== Title bar (drag region) ===================== -->
        <Grid x:Name="AppTitleBar" Height="40" VerticalAlignment="Top" Background="Transparent">
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="14,0,0,0"
                        HorizontalAlignment="Left" VerticalAlignment="Center">
                <Image x:Name="TitleLogo" Width="20" Height="20" VerticalAlignment="Center" />
                <TextBlock Text="Galileo" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center" />
            </StackPanel>
            <TextBlock x:Name="ModeLabel" Text="" Opacity="0.75" FontSize="13"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis" Margin="170,0,170,0" />
        </Grid>

        <!-- Subtle status text -->
        <TextBlock x:Name="StatusText" Text="Ready" FontSize="12" Opacity="0.55"
                   HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="16,0,0,8"
                   IsHitTestVisible="False" />
    </Grid>
</Window>
