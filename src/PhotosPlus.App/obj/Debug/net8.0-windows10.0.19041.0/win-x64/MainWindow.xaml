<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="PhotosPlus.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid x:ConnectionId='2' x:Name="RootGrid"                           
          AllowDrop="True"                                                  >
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ===================== Command bar ===================== -->
        <CommandBar x:ConnectionId='3' x:Name="MainCommandBar" Grid.Row="0"
                    DefaultLabelPosition="Right"
                    IsOpen="False"
                    HorizontalContentAlignment="Stretch">
            <CommandBar.Content>
                <StackPanel Orientation="Horizontal" Spacing="8" Margin="12,0,0,0" VerticalAlignment="Center">
                    <FontIcon Glyph="&#xEB9F;" FontFamily="Segoe MDL2 Assets" />
                    <TextBlock Text="PhotosPlus" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <TextBlock x:ConnectionId='20' x:Name="ModeLabel" Text="" Opacity="0.6" VerticalAlignment="Center" />
                </StackPanel>
            </CommandBar.Content>

            <AppBarButton x:ConnectionId='21' x:Name="OpenButton" Label="Open" Icon="OpenFile">
                <AppBarButton.Flyout>
                    <MenuFlyout>
                        <MenuFlyoutItem x:ConnectionId='38' Text="Open file…"                       >
                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8E5;" FontFamily="Segoe MDL2 Assets" /></MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem x:ConnectionId='39' Text="Open folder…"                         >
                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE838;" FontFamily="Segoe MDL2 Assets" /></MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                    </MenuFlyout>
                </AppBarButton.Flyout>
            </AppBarButton>
            <AppBarButton x:ConnectionId='22' x:Name="BackButton" Label="Gallery" Icon="Pictures" Visibility="Collapsed"
                          ToolTipService.ToolTip="Gallery options">
                <AppBarButton.Flyout>
                    <MenuFlyout>
                        <MenuFlyoutItem x:ConnectionId='36' Text="Back to gallery (Esc)"                            >
                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE72B;" FontFamily="Segoe MDL2 Assets" /></MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutSeparator />
                        <MenuFlyoutItem x:ConnectionId='37' Text="Close gallery"                           >
                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8BB;" FontFamily="Segoe MDL2 Assets" /></MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                    </MenuFlyout>
                </AppBarButton.Flyout>
            </AppBarButton>
            <AppBarSeparator x:ConnectionId='23' x:Name="ViewerSep1" Visibility="Collapsed" />
            <AppBarButton x:ConnectionId='24' x:Name="PrevButton" Label="Previous" Icon="Previous"                    Visibility="Collapsed" />
            <AppBarButton x:ConnectionId='25' x:Name="NextButton" Label="Next" Icon="Next"                    Visibility="Collapsed" />
            <AppBarButton x:ConnectionId='26' x:Name="ZoomInButton" Label="Zoom in" Icon="ZoomIn"                      Visibility="Collapsed" />
            <AppBarButton x:ConnectionId='27' x:Name="ZoomOutButton" Label="Zoom out" Icon="ZoomOut"                       Visibility="Collapsed" />
            <AppBarButton x:ConnectionId='28' x:Name="FitButton" Label="Fit" Icon="FullScreen"                   Visibility="Collapsed" />
            <AppBarButton x:ConnectionId='29' x:Name="RotateButton" Label="Rotate" Icon="Rotate"                      Visibility="Collapsed" />
            <AppBarButton x:ConnectionId='30' x:Name="FavoriteButton" Label="Favorite" Icon="OutlineStar"                        Visibility="Collapsed" />

            <!-- ===== Eye toggle: the headline feature ===== -->
            <AppBarButton x:ConnectionId='31' x:Name="EyeButton" Label="Hide"                   Visibility="Collapsed"
                          ToolTipService.ToolTip="Hide / un-hide this photo (H)">
                <AppBarButton.Icon>
                    <FontIcon x:ConnectionId='33' x:Name="EyeIcon" Glyph="&#xE890;" FontFamily="Segoe MDL2 Assets" />
                </AppBarButton.Icon>
                <AppBarButton.Flyout>
                    <MenuFlyout>
                        <MenuFlyoutItem x:ConnectionId='34' Text="Obscure in view (H)"                         >
                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xED1A;" FontFamily="Segoe MDL2 Assets" /></MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem x:ConnectionId='35' Text="Hide permanently (move to Hidden album)"                               >
                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE890;" FontFamily="Segoe MDL2 Assets" /></MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                    </MenuFlyout>
                </AppBarButton.Flyout>
            </AppBarButton>

            <AppBarButton x:ConnectionId='32' x:Name="SlideshowButton" Label="Slideshow"                        
                          ToolTipService.ToolTip="Start slideshow (F5)">
                <AppBarButton.Icon><FontIcon Glyph="&#xE786;" FontFamily="Segoe MDL2 Assets" /></AppBarButton.Icon>
            </AppBarButton>

            <CommandBar.SecondaryCommands>
                <AppBarButton x:ConnectionId='40' x:Name="CloseGalleryButton" Label="Close gallery"                           >
                    <AppBarButton.Icon><FontIcon Glyph="&#xE8BB;" FontFamily="Segoe MDL2 Assets" /></AppBarButton.Icon>
                </AppBarButton>
                <AppBarToggleButton x:ConnectionId='41' x:Name="HiddenAlbumButton" Label="Show Hidden album"                          >
                    <AppBarToggleButton.Icon><FontIcon Glyph="&#xE890;" FontFamily="Segoe MDL2 Assets" /></AppBarToggleButton.Icon>
                </AppBarToggleButton>
                <AppBarToggleButton x:ConnectionId='42' x:Name="FavoritesFilterButton" Label="Favorites only"                              >
                    <AppBarToggleButton.Icon><FontIcon Glyph="&#xE735;" FontFamily="Segoe MDL2 Assets" /></AppBarToggleButton.Icon>
                </AppBarToggleButton>
                <AppBarButton x:ConnectionId='43' x:Name="InfoButton" Label="Photo info"                   >
                    <AppBarButton.Icon><FontIcon Glyph="&#xE946;" FontFamily="Segoe MDL2 Assets" /></AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton x:ConnectionId='44' x:Name="RevealButton" Label="Reveal in Explorer"                     >
                    <AppBarButton.Icon><FontIcon Glyph="&#xEC50;" FontFamily="Segoe MDL2 Assets" /></AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton x:ConnectionId='45' x:Name="DeleteButton" Label="Delete"                     >
                    <AppBarButton.Icon><FontIcon Glyph="&#xE74D;" FontFamily="Segoe MDL2 Assets" /></AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton x:ConnectionId='46' x:Name="FullScreenButton" Label="Full screen (F11)"                         >
                    <AppBarButton.Icon><FontIcon Glyph="&#xE740;" FontFamily="Segoe MDL2 Assets" /></AppBarButton.Icon>
                </AppBarButton>
            </CommandBar.SecondaryCommands>
        </CommandBar>

        <!-- ===================== Content ===================== -->
        <Grid Grid.Row="1">

            <!-- Gallery -->
            <Grid x:ConnectionId='5' x:Name="GalleryView">
                <GridView x:ConnectionId='15' x:Name="PhotoGrid"
                          Padding="12"
                          SelectionMode="None"
                          IsItemClickEnabled="True"
                                                         
                                                                                       >
                    <GridView.ItemTemplate>
                        <DataTemplate>
                            <Grid Width="200" Height="200" Margin="4"
                                  CornerRadius="6" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                                <Image Source="{Binding Thumbnail}" Stretch="UniformToFill" />
                                <Border Background="#88000000" VerticalAlignment="Bottom" Padding="6,3">
                                    <TextBlock Text="{Binding FileName}" FontSize="11"
                                               TextTrimming="CharacterEllipsis" Foreground="White" />
                                </Border>
                                <FontIcon Glyph="&#xE735;" FontFamily="Segoe MDL2 Assets"
                                          Foreground="Gold" FontSize="16"
                                          HorizontalAlignment="Right" VerticalAlignment="Top" Margin="8"
                                          Visibility="{Binding FavoriteVisibility}" />
                                <Border Background="#AA000000" CornerRadius="6"
                                        Visibility="{Binding HiddenVisibility}">
                                    <FontIcon Glyph="&#xED1A;" FontFamily="Segoe MDL2 Assets"
                                              Foreground="White" FontSize="28"
                                              HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>

                <StackPanel x:ConnectionId='16' x:Name="EmptyState" Visibility="Visible"
                            HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                    <FontIcon Glyph="&#xEB9F;" FontFamily="Segoe MDL2 Assets" FontSize="48" Opacity="0.5" />
                    <TextBlock Text="Open a file or folder — or drag photos here" Opacity="0.7" FontSize="16" HorizontalAlignment="Center" />
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                        <Button x:ConnectionId='17' Content="Open file"                        />
                        <Button x:ConnectionId='18' Content="Open folder"                          />
                    </StackPanel>
                </StackPanel>
            </Grid>

            <!-- Viewer -->
            <Grid x:ConnectionId='6' x:Name="ViewerView" Visibility="Collapsed" Background="{ThemeResource SolidBackgroundFillColorBaseBrush}">
                <ScrollViewer x:ConnectionId='7' x:Name="ImageScroller"
                              ZoomMode="Enabled"
                              HorizontalScrollMode="Enabled" VerticalScrollMode="Enabled"
                              HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                              MinZoomFactor="0.1" MaxZoomFactor="8"
                                                                       
                                                                                     
                                                                     >
                    <Image x:ConnectionId='13' x:Name="ViewerImage" Stretch="Uniform" RenderTransformOrigin="0.5,0.5">
                        <Image.RenderTransform>
                            <RotateTransform x:ConnectionId='14' x:Name="ViewerRotate" />
                        </Image.RenderTransform>
                    </Image>
                </ScrollViewer>

                <!-- Eye obscure: plain black curtain over the current photo -->
                <Grid x:ConnectionId='8' x:Name="ObscureOverlay" Visibility="Collapsed" Background="Black" />

                <!-- Edge nav buttons -->
                <Button x:ConnectionId='9'                    HorizontalAlignment="Left" VerticalAlignment="Center" Margin="8"
                        Width="48" Height="48" CornerRadius="24" Background="#66000000">
                    <FontIcon Glyph="&#xE76B;" FontFamily="Segoe MDL2 Assets" Foreground="White" />
                </Button>
                <Button x:ConnectionId='10'                    HorizontalAlignment="Right" VerticalAlignment="Center" Margin="8"
                        Width="48" Height="48" CornerRadius="24" Background="#66000000">
                    <FontIcon Glyph="&#xE76C;" FontFamily="Segoe MDL2 Assets" Foreground="White" />
                </Button>

                <!-- Metadata panel -->
                <Border x:ConnectionId='11' x:Name="InfoPanel" Visibility="Collapsed"
                        HorizontalAlignment="Right" VerticalAlignment="Top" Margin="12"
                        Width="320" Padding="16" CornerRadius="8"
                        Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Photo info" FontWeight="SemiBold" FontSize="16" />
                        <TextBlock x:ConnectionId='12' x:Name="InfoText" TextWrapping="Wrap" FontSize="13" Opacity="0.9" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- ===================== Status bar ===================== -->
        <Border Grid.Row="2" Padding="12,4" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <TextBlock x:ConnectionId='4' x:Name="StatusText" Text="Ready" FontSize="12" Opacity="0.7" />
        </Border>
    </Grid>
</Window>

