<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="PhotosPlus.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid x:ConnectionId='2' x:Name="RootGrid"                           
          AllowDrop="True"                                                  >

        <!-- ===================== Gallery ===================== -->
        <Grid x:ConnectionId='3' x:Name="GalleryView">
            <GridView x:ConnectionId='49' x:Name="PhotoGrid"
                      Padding="24,56,24,32"
                      SelectionMode="None"
                      IsItemClickEnabled="True"
                                                     
                                                                                   >
                <GridView.ItemTemplate>
                    <DataTemplate>
                        <Grid Width="196" Height="196" Margin="5"
                              CornerRadius="10" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                            <Image Source="{Binding Thumbnail}" Stretch="UniformToFill" />
                            <Border Background="#B0000000" VerticalAlignment="Bottom" Padding="8,4">
                                <TextBlock Text="{Binding FileName}" FontSize="11"
                                           TextTrimming="CharacterEllipsis" Foreground="White" />
                            </Border>
                            <FontIcon Glyph="&#xE735;" FontFamily="Segoe MDL2 Assets"
                                      Foreground="Gold" FontSize="16"
                                      HorizontalAlignment="Right" VerticalAlignment="Top" Margin="10"
                                      Visibility="{Binding FavoriteVisibility}" />
                            <Border Background="#CC000000" CornerRadius="10"
                                    Visibility="{Binding HiddenVisibility}">
                                <FontIcon Glyph="&#xED1A;" FontFamily="Segoe MDL2 Assets"
                                          Foreground="White" FontSize="28"
                                          HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </Grid>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>

            <!-- Empty state -->
            <StackPanel x:ConnectionId='50' x:Name="EmptyState" Visibility="Visible"
                        HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="14" MaxWidth="420">
                <FontIcon Glyph="&#xEB9F;" FontFamily="Segoe MDL2 Assets" FontSize="56" Opacity="0.45" />
                <TextBlock Text="Your photos, beautifully" FontSize="24" FontWeight="SemiBold" HorizontalAlignment="Center" />
                <TextBlock Text="Open a file or folder, or drag photos anywhere onto this window."
                           Opacity="0.7" FontSize="14" TextWrapping="Wrap" TextAlignment="Center" />
                <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center" Margin="0,4,0,0">
                    <Button x:ConnectionId='60' Content="Open file"                        Style="{StaticResource AccentButtonStyle}" />
                    <Button x:ConnectionId='61' Content="Open folder"                          />
                </StackPanel>
            </StackPanel>

            <!-- Floating gallery toolbar -->
            <Border HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,48,16,0"
                    CornerRadius="24" Padding="4" Background="{ThemeResource AcrylicInAppFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Orientation="Horizontal" Spacing="2">
                    <Button x:ConnectionId='51' x:Name="OpenButton" Style="{StaticResource GlyphButton}"
                            ToolTipService.ToolTip="Open">
                        <FontIcon Glyph="&#xE8E5;" FontFamily="Segoe MDL2 Assets" />
                        <Button.Flyout>
                            <MenuFlyout>
                                <MenuFlyoutItem x:ConnectionId='58' Text="Open file…"                       >
                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8E5;" FontFamily="Segoe MDL2 Assets" /></MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem x:ConnectionId='59' Text="Open folder…"                         >
                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE838;" FontFamily="Segoe MDL2 Assets" /></MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>
                    <Button x:ConnectionId='52' Style="{StaticResource GlyphButton}"                        
                            ToolTipService.ToolTip="Slideshow (F5)">
                        <FontIcon Glyph="&#xE786;" FontFamily="Segoe MDL2 Assets" />
                    </Button>
                    <Button x:ConnectionId='53' Style="{StaticResource GlyphButton}"                      
                            ToolTipService.ToolTip="Collage">
                        <FontIcon Glyph="&#xE8A9;" FontFamily="Segoe MDL2 Assets" />
                    </Button>
                    <Button x:ConnectionId='54' Style="{StaticResource GlyphButton}"                       
                            ToolTipService.ToolTip="Settings">
                        <FontIcon Glyph="&#xE713;" FontFamily="Segoe MDL2 Assets" />
                    </Button>
                    <Button Style="{StaticResource GlyphButton}" ToolTipService.ToolTip="More">
                        <FontIcon Glyph="&#xE712;" FontFamily="Segoe MDL2 Assets" />
                        <Button.Flyout>
                            <MenuFlyout>
                                <ToggleMenuFlyoutItem x:ConnectionId='55' x:Name="HiddenAlbumButton" Text="Show Hidden album"                           />
                                <ToggleMenuFlyoutItem x:ConnectionId='56' x:Name="FavoritesFilterButton" Text="Favorites only"                               />
                                <MenuFlyoutSeparator />
                                <MenuFlyoutItem x:ConnectionId='57' Text="Close gallery"                           >
                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8BB;" FontFamily="Segoe MDL2 Assets" /></MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ===================== Viewer ===================== -->
        <Grid x:ConnectionId='4' x:Name="ViewerView" Visibility="Collapsed" Background="#FF101013"
                                                    >

            <Grid x:ConnectionId='24' x:Name="ImageHost" Background="Transparent"
                                                     
                                                                     
                                                           
                                                       
                                                             
                                                       >
                <Image x:ConnectionId='47' x:Name="ViewerImage" Stretch="Uniform"
                       HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                       RenderTransformOrigin="0.5,0.5"
                                                            >
                    <Image.RenderTransform>
                        <CompositeTransform x:ConnectionId='48' x:Name="ViewerTransform" />
                    </Image.RenderTransform>
                </Image>
            </Grid>

            <!-- Eye obscure: plain black curtain -->
            <Grid x:ConnectionId='25' x:Name="ObscureOverlay" Visibility="Collapsed" Background="Black" />

            <!-- Floating chrome that auto-hides -->
            <Grid x:ConnectionId='26' x:Name="ViewerChrome">

                <!-- Top-left: back -->
                <Border HorizontalAlignment="Left" VerticalAlignment="Top" Margin="16,48,0,0"
                        CornerRadius="22" Padding="4" Background="{StaticResource PillBrush}">
                    <Button x:ConnectionId='46' Style="{StaticResource GlyphButton}" Foreground="White"                            
                            ToolTipService.ToolTip="Back to gallery (Esc)">
                        <FontIcon Glyph="&#xE72B;" FontFamily="Segoe MDL2 Assets" />
                    </Button>
                </Border>

                <!-- Top-right: actions -->
                <Border HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,48,16,0"
                        CornerRadius="24" Padding="4" Background="{StaticResource PillBrush}">
                    <StackPanel Orientation="Horizontal" Spacing="2">
                        <Button x:ConnectionId='36' x:Name="FavoriteButton" Style="{StaticResource GlyphButton}" Foreground="White"
                                                       ToolTipService.ToolTip="Favorite">
                            <FontIcon x:ConnectionId='45' x:Name="FavoriteIcon" Glyph="&#xE734;" FontFamily="Segoe MDL2 Assets" />
                        </Button>
                        <Button x:ConnectionId='37' x:Name="EyeButton" Style="{StaticResource GlyphButton}" Foreground="White"
                                                  ToolTipService.ToolTip="Hide / reveal (H)">
                            <FontIcon x:ConnectionId='42' x:Name="EyeIcon" Glyph="&#xE890;" FontFamily="Segoe MDL2 Assets" />
                            <Button.Flyout>
                                <MenuFlyout Placement="Bottom">
                                    <MenuFlyoutItem x:ConnectionId='43' Text="Hide / reveal in view (H)"                         >
                                        <MenuFlyoutItem.Icon><FontIcon Glyph="&#xED1A;" FontFamily="Segoe MDL2 Assets" /></MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutItem x:ConnectionId='44' Text="Hide permanently (Hidden album)"                               >
                                        <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE890;" FontFamily="Segoe MDL2 Assets" /></MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                </MenuFlyout>
                            </Button.Flyout>
                        </Button>
                        <Button x:ConnectionId='38' Style="{StaticResource GlyphButton}" Foreground="White"                     
                                ToolTipService.ToolTip="Rotate (R)">
                            <FontIcon Glyph="&#xE7AD;" FontFamily="Segoe MDL2 Assets" />
                        </Button>
                        <Button x:ConnectionId='39' Style="{StaticResource GlyphButton}" Foreground="White"                   
                                ToolTipService.ToolTip="Photo info">
                            <FontIcon Glyph="&#xE946;" FontFamily="Segoe MDL2 Assets" />
                        </Button>
                        <Button x:ConnectionId='40' Style="{StaticResource GlyphButton}" Foreground="White"                     
                                ToolTipService.ToolTip="Reveal in Explorer">
                            <FontIcon Glyph="&#xEC50;" FontFamily="Segoe MDL2 Assets" />
                        </Button>
                        <Button x:ConnectionId='41' Style="{StaticResource GlyphButton}" Foreground="White"                     
                                ToolTipService.ToolTip="Delete">
                            <FontIcon Glyph="&#xE74D;" FontFamily="Segoe MDL2 Assets" />
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Bottom-centre: navigation & zoom -->
                <Border HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,28"
                        CornerRadius="26" Padding="6" Background="{StaticResource PillBrush}">
                    <StackPanel Orientation="Horizontal" Spacing="2">
                        <Button x:ConnectionId='29' Style="{StaticResource GlyphButton}" Foreground="White"                   
                                ToolTipService.ToolTip="Previous">
                            <FontIcon Glyph="&#xE76B;" FontFamily="Segoe MDL2 Assets" />
                        </Button>
                        <Button x:ConnectionId='30' Style="{StaticResource GlyphButton}" Foreground="White"                      
                                ToolTipService.ToolTip="Zoom out">
                            <FontIcon Glyph="&#xE71F;" FontFamily="Segoe MDL2 Assets" />
                        </Button>
                        <Button x:ConnectionId='31' Style="{StaticResource GlyphButton}" Foreground="White"                  
                                ToolTipService.ToolTip="Fit (0)">
                            <FontIcon Glyph="&#xE9A6;" FontFamily="Segoe MDL2 Assets" />
                        </Button>
                        <Button x:ConnectionId='32' Style="{StaticResource GlyphButton}" Foreground="White"                     
                                ToolTipService.ToolTip="Zoom in">
                            <FontIcon Glyph="&#xE8A3;" FontFamily="Segoe MDL2 Assets" />
                        </Button>
                        <Button x:ConnectionId='33' Style="{StaticResource GlyphButton}" Foreground="White"                   
                                ToolTipService.ToolTip="Next">
                            <FontIcon Glyph="&#xE76C;" FontFamily="Segoe MDL2 Assets" />
                        </Button>
                        <Border Width="1" Margin="6,8" Background="#33FFFFFF" />
                        <Button x:ConnectionId='34' Style="{StaticResource GlyphButton}" Foreground="White"                        
                                ToolTipService.ToolTip="Slideshow (F5)">
                            <FontIcon Glyph="&#xE786;" FontFamily="Segoe MDL2 Assets" />
                        </Button>
                        <Button x:ConnectionId='35' Style="{StaticResource GlyphButton}" Foreground="White"                         
                                ToolTipService.ToolTip="Full screen (F11)">
                            <FontIcon Glyph="&#xE740;" FontFamily="Segoe MDL2 Assets" />
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Metadata panel -->
            <Border x:ConnectionId='27' x:Name="InfoPanel" Visibility="Collapsed"
                    HorizontalAlignment="Right" VerticalAlignment="Top" Margin="16,104,16,0"
                    Width="330" Padding="18" CornerRadius="12"
                    Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="6">
                    <TextBlock Text="Photo info" FontWeight="SemiBold" FontSize="16" />
                    <TextBlock x:ConnectionId='28' x:Name="InfoText" TextWrapping="Wrap" FontSize="13" Opacity="0.9" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- ===================== Collage ===================== -->
        <Grid x:ConnectionId='5' x:Name="CollageView" Visibility="Collapsed" Background="#FF101013">
            <Canvas x:ConnectionId='17' x:Name="CollageCanvas"                                         />

            <!-- Floating collage controls -->
            <Border HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,28"
                    CornerRadius="26" Padding="6" Background="{StaticResource PillBrush}">
                <StackPanel Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                    <Button x:ConnectionId='18' Style="{StaticResource GlyphButton}" Foreground="White"                          
                            ToolTipService.ToolTip="Back to gallery (Esc)">
                        <FontIcon Glyph="&#xE72B;" FontFamily="Segoe MDL2 Assets" />
                    </Button>
                    <Border Width="1" Margin="6,8" Background="#33FFFFFF" />
                    <Button x:ConnectionId='19' Style="{StaticResource GlyphButton}" Foreground="White"                           
                            ToolTipService.ToolTip="Fewer photos">
                        <FontIcon Glyph="&#xE738;" FontFamily="Segoe MDL2 Assets" />
                    </Button>
                    <TextBlock x:ConnectionId='20' x:Name="CollageCountText" Foreground="White" VerticalAlignment="Center"
                               MinWidth="64" TextAlignment="Center" Text="0 photos" />
                    <Button x:ConnectionId='21' Style="{StaticResource GlyphButton}" Foreground="White"                          
                            ToolTipService.ToolTip="More photos">
                        <FontIcon Glyph="&#xE710;" FontFamily="Segoe MDL2 Assets" />
                    </Button>
                    <Border Width="1" Margin="6,8" Background="#33FFFFFF" />
                    <Button x:ConnectionId='22' Style="{StaticResource GlyphButton}" Foreground="White"                             
                            ToolTipService.ToolTip="Shuffle">
                        <FontIcon Glyph="&#xE8B1;" FontFamily="Segoe MDL2 Assets" />
                    </Button>
                    <Button x:ConnectionId='23' Style="{StaticResource GlyphButton}" Foreground="White"                          
                            ToolTipService.ToolTip="Save collage…">
                        <FontIcon Glyph="&#xE74E;" FontFamily="Segoe MDL2 Assets" />
                    </Button>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ===================== Settings overlay ===================== -->
        <Grid x:ConnectionId='6' x:Name="SettingsOverlay" Visibility="Collapsed" Background="#88000000"
                                           >
            <Border x:ConnectionId='10' Width="420" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Background="{ThemeResource LayerFillColorAltBrush}" CornerRadius="14"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    Padding="24"                             >
                <StackPanel Spacing="18">
                    <Grid>
                        <TextBlock Text="Settings" FontSize="22" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <Button x:ConnectionId='16' Style="{StaticResource GlyphButton}"                            
                                HorizontalAlignment="Right" ToolTipService.ToolTip="Close">
                            <FontIcon Glyph="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="14" />
                        </Button>
                    </Grid>

                    <TextBlock Text="Slideshow" FontWeight="SemiBold" Opacity="0.8" />

                    <Grid>
                        <TextBlock Text="Seconds per photo" VerticalAlignment="Center" />
                        <TextBlock x:ConnectionId='15' x:Name="SlideshowSecondsValue" Text="4s" HorizontalAlignment="Right" VerticalAlignment="Center" Opacity="0.8" />
                    </Grid>
                    <Slider x:ConnectionId='11' x:Name="SlideshowSecondsSlider" Minimum="2" Maximum="30" StepFrequency="1"
                                                                               />

                    <Grid>
                        <TextBlock Text="Shuffle" VerticalAlignment="Center" />
                        <ToggleSwitch x:ConnectionId='14' x:Name="ShuffleSwitch" HorizontalAlignment="Right"                                 />
                    </Grid>
                    <Grid>
                        <TextBlock Text="Loop" VerticalAlignment="Center" />
                        <ToggleSwitch x:ConnectionId='13' x:Name="LoopSwitch" HorizontalAlignment="Right"                              />
                    </Grid>
                    <Grid>
                        <TextBlock Text="Transition" VerticalAlignment="Center" />
                        <ComboBox x:ConnectionId='12' x:Name="TransitionCombo" HorizontalAlignment="Right" MinWidth="160"
                                                                                     >
                            <ComboBoxItem Content="None" />
                            <ComboBoxItem Content="Crossfade" />
                            <ComboBoxItem Content="Ken Burns" />
                        </ComboBox>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ===================== Title bar (drag region) ===================== -->
        <Grid x:ConnectionId='7' x:Name="AppTitleBar" Height="40" VerticalAlignment="Top" Background="Transparent">
            <StackPanel Orientation="Horizontal" Spacing="10" Margin="16,0,0,0" VerticalAlignment="Center">
                <FontIcon Glyph="&#xEB9F;" FontFamily="Segoe MDL2 Assets" FontSize="14" Opacity="0.8" />
                <TextBlock Text="PhotosPlus" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center" />
                <TextBlock x:ConnectionId='9' x:Name="ModeLabel" Text="" Opacity="0.6" FontSize="13" VerticalAlignment="Center" />
            </StackPanel>
        </Grid>

        <!-- Subtle status text -->
        <TextBlock x:ConnectionId='8' x:Name="StatusText" Text="Ready" FontSize="12" Opacity="0.55"
                   HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="16,0,0,8"
                   IsHitTestVisible="False" />
    </Grid>
</Window>

