<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="PhotosPlus.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:PhotosPlus.Models"
    xmlns:conv="using:PhotosPlus.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Grid x:Name="RootGrid" KeyDown="RootGrid_KeyDown">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ===================== Command bar ===================== -->
        <CommandBar x:Name="MainCommandBar" Grid.Row="0"
                    DefaultLabelPosition="Right"
                    IsOpen="False"
                    HorizontalContentAlignment="Stretch">
            <CommandBar.Content>
                <StackPanel Orientation="Horizontal" Spacing="8" Margin="12,0,0,0" VerticalAlignment="Center">
                    <FontIcon Glyph="&#xEB9F;" FontFamily="Segoe MDL2 Assets" />
                    <TextBlock Text="PhotosPlus" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <TextBlock x:Name="ModeLabel" Text="" Opacity="0.6" VerticalAlignment="Center" />
                </StackPanel>
            </CommandBar.Content>

            <AppBarButton x:Name="OpenButton" Label="Open folder" Icon="OpenLocal" Click="OpenFolder_Click" />
            <AppBarButton x:Name="BackButton" Label="Gallery" Icon="Pictures" Click="BackToGallery_Click" Visibility="Collapsed" />
            <AppBarSeparator x:Name="ViewerSep1" Visibility="Collapsed" />
            <AppBarButton x:Name="PrevButton" Label="Previous" Icon="Previous" Click="Prev_Click" Visibility="Collapsed" />
            <AppBarButton x:Name="NextButton" Label="Next" Icon="Next" Click="Next_Click" Visibility="Collapsed" />
            <AppBarButton x:Name="ZoomInButton" Label="Zoom in" Icon="ZoomIn" Click="ZoomIn_Click" Visibility="Collapsed" />
            <AppBarButton x:Name="ZoomOutButton" Label="Zoom out" Icon="ZoomOut" Click="ZoomOut_Click" Visibility="Collapsed" />
            <AppBarButton x:Name="FitButton" Label="Fit" Icon="FullScreen" Click="Fit_Click" Visibility="Collapsed" />
            <AppBarButton x:Name="RotateButton" Label="Rotate" Icon="Rotate" Click="Rotate_Click" Visibility="Collapsed" />
            <AppBarButton x:Name="FavoriteButton" Label="Favorite" Icon="OutlineStar" Click="Favorite_Click" Visibility="Collapsed" />

            <!-- ===== Eye toggle: the headline feature ===== -->
            <AppBarButton x:Name="EyeButton" Label="Hide" Click="Eye_Click" Visibility="Collapsed"
                          ToolTipService.ToolTip="Hide / un-hide this photo (H)">
                <AppBarButton.Icon>
                    <FontIcon x:Name="EyeIcon" Glyph="&#xE7B3;" FontFamily="Segoe MDL2 Assets" />
                </AppBarButton.Icon>
                <AppBarButton.Flyout>
                    <MenuFlyout>
                        <MenuFlyoutItem Text="Obscure in view (H)" Click="EyeObscure_Click">
                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xED1A;" FontFamily="Segoe MDL2 Assets" /></MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem Text="Hide permanently (move to Hidden album)" Click="EyeHidePermanent_Click">
                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE890;" FontFamily="Segoe MDL2 Assets" /></MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                    </MenuFlyout>
                </AppBarButton.Flyout>
            </AppBarButton>

            <AppBarButton x:Name="SlideshowButton" Label="Slideshow" Click="Slideshow_Click"
                          ToolTipService.ToolTip="Start slideshow (F5)">
                <AppBarButton.Icon><FontIcon Glyph="&#xE786;" FontFamily="Segoe MDL2 Assets" /></AppBarButton.Icon>
            </AppBarButton>

            <CommandBar.SecondaryCommands>
                <AppBarToggleButton x:Name="HiddenAlbumButton" Label="Show Hidden album" Click="HiddenAlbum_Click">
                    <AppBarToggleButton.Icon><FontIcon Glyph="&#xE890;" FontFamily="Segoe MDL2 Assets" /></AppBarToggleButton.Icon>
                </AppBarToggleButton>
                <AppBarToggleButton x:Name="FavoritesFilterButton" Label="Favorites only" Click="FavoritesFilter_Click">
                    <AppBarToggleButton.Icon><FontIcon Glyph="&#xE735;" FontFamily="Segoe MDL2 Assets" /></AppBarToggleButton.Icon>
                </AppBarToggleButton>
                <AppBarButton x:Name="InfoButton" Label="Photo info" Click="Info_Click">
                    <AppBarButton.Icon><FontIcon Glyph="&#xE946;" FontFamily="Segoe MDL2 Assets" /></AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton x:Name="RevealButton" Label="Reveal in Explorer" Click="Reveal_Click">
                    <AppBarButton.Icon><FontIcon Glyph="&#xEC50;" FontFamily="Segoe MDL2 Assets" /></AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton x:Name="DeleteButton" Label="Delete" Click="Delete_Click">
                    <AppBarButton.Icon><FontIcon Glyph="&#xE74D;" FontFamily="Segoe MDL2 Assets" /></AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton x:Name="FullScreenButton" Label="Full screen (F11)" Click="FullScreen_Click">
                    <AppBarButton.Icon><FontIcon Glyph="&#xE740;" FontFamily="Segoe MDL2 Assets" /></AppBarButton.Icon>
                </AppBarButton>
            </CommandBar.SecondaryCommands>
        </CommandBar>

        <!-- ===================== Content ===================== -->
        <Grid Grid.Row="1">

            <!-- Gallery -->
            <Grid x:Name="GalleryView">
                <GridView x:Name="PhotoGrid"
                          Padding="12"
                          SelectionMode="None"
                          IsItemClickEnabled="True"
                          ItemClick="PhotoGrid_ItemClick"
                          ContainerContentChanging="PhotoGrid_ContainerContentChanging">
                    <GridView.ItemTemplate>
                        <DataTemplate x:DataType="models:PhotoItem">
                            <Grid Width="200" Height="200" Margin="4"
                                  CornerRadius="6" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                                <Image Source="{Binding Thumbnail}" Stretch="UniformToFill" />
                                <Border Background="#88000000" VerticalAlignment="Bottom" Padding="6,3">
                                    <TextBlock Text="{Binding FileName}" FontSize="11"
                                               TextTrimming="CharacterEllipsis" Foreground="White" />
                                </Border>
                                <FontIcon Glyph="&#xE735;" FontFamily="Segoe MDL2 Assets"
                                          Foreground="Gold" FontSize="16"
                                          HorizontalAlignment="Right" VerticalAlignment="Top" Margin="8"
                                          Visibility="{Binding IsFavorite, Converter={StaticResource BoolToVis}}" />
                                <Border Background="#AA000000" CornerRadius="6"
                                        Visibility="{Binding IsHidden, Converter={StaticResource BoolToVis}}">
                                    <FontIcon Glyph="&#xED1A;" FontFamily="Segoe MDL2 Assets"
                                              Foreground="White" FontSize="28"
                                              HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>

                <StackPanel x:Name="EmptyState" Visibility="Visible"
                            HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                    <FontIcon Glyph="&#xEB9F;" FontFamily="Segoe MDL2 Assets" FontSize="48" Opacity="0.5" />
                    <TextBlock Text="Open a folder to view your photos" Opacity="0.7" FontSize="16" />
                    <Button Content="Open folder…" Click="OpenFolder_Click" HorizontalAlignment="Center" />
                </StackPanel>
            </Grid>

            <!-- Viewer -->
            <Grid x:Name="ViewerView" Visibility="Collapsed" Background="{ThemeResource SolidBackgroundFillColorBaseBrush}">
                <ScrollViewer x:Name="ImageScroller"
                              ZoomMode="Enabled"
                              HorizontalScrollMode="Enabled" VerticalScrollMode="Enabled"
                              HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                              MinZoomFactor="0.1" MaxZoomFactor="8"
                              DoubleTapped="ImageScroller_DoubleTapped">
                    <Image x:Name="ViewerImage" Stretch="Uniform">
                        <Image.RenderTransform>
                            <RotateTransform x:Name="ViewerRotate" CenterX="0.5" CenterY="0.5" />
                        </Image.RenderTransform>
                    </Image>
                </ScrollViewer>

                <!-- Eye obscure / privacy curtain -->
                <Grid x:Name="ObscureOverlay" Visibility="Collapsed" Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="14">
                        <FontIcon Glyph="&#xED1A;" FontFamily="Segoe MDL2 Assets" FontSize="64" Opacity="0.8" />
                        <TextBlock Text="Photo hidden" FontSize="22" HorizontalAlignment="Center" />
                        <TextBlock Text="Press H or click the eye to reveal" Opacity="0.7" HorizontalAlignment="Center" />
                    </StackPanel>
                </Grid>

                <!-- Edge nav buttons -->
                <Button Click="Prev_Click" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="8"
                        Width="48" Height="48" CornerRadius="24" Background="#66000000">
                    <FontIcon Glyph="&#xE76B;" FontFamily="Segoe MDL2 Assets" Foreground="White" />
                </Button>
                <Button Click="Next_Click" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="8"
                        Width="48" Height="48" CornerRadius="24" Background="#66000000">
                    <FontIcon Glyph="&#xE76C;" FontFamily="Segoe MDL2 Assets" Foreground="White" />
                </Button>

                <!-- Metadata panel -->
                <Border x:Name="InfoPanel" Visibility="Collapsed"
                        HorizontalAlignment="Right" VerticalAlignment="Top" Margin="12"
                        Width="320" Padding="16" CornerRadius="8"
                        Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Photo info" FontWeight="SemiBold" FontSize="16" />
                        <TextBlock x:Name="InfoText" TextWrapping="Wrap" FontSize="13" Opacity="0.9" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- ===================== Status bar ===================== -->
        <Border Grid.Row="2" Padding="12,4" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <TextBlock x:Name="StatusText" Text="Ready" FontSize="12" Opacity="0.7" />
        </Border>
    </Grid>
</Window>
