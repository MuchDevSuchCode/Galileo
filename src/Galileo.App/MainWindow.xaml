<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Galileo.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid x:Name="RootGrid" KeyDown="RootGrid_KeyDown"
          AllowDrop="True" DragOver="RootGrid_DragOver" Drop="RootGrid_Drop">

        <!-- ===================== File Explorer (home) ===================== -->
        <Grid x:Name="ExplorerView">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240" x:Name="SidebarCol" MinWidth="160" MaxWidth="560" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="0" x:Name="TerminalCol" />
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Grid Grid.Column="0" Background="{ThemeResource LayerFillColorAltBrush}"
                  BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,1,0">
                <ScrollViewer Padding="8,48,8,12">
                    <StackPanel Spacing="2">
                        <Button Click="NavHome_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                Background="Transparent" BorderThickness="0" Padding="10,8">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE80F;" FontFamily="Segoe Fluent Icons" FontSize="16" />
                                <TextBlock Text="Home (This PC)" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <TextBlock Text="Quick access" Opacity="0.6" FontSize="12" Margin="10,12,0,4" />
                        <ListView x:Name="QuickAccessList" SelectionMode="None" IsItemClickEnabled="True"
                                  ItemClick="Sidebar_ItemClick">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="10" Height="32">
                                        <Image Source="{Binding Icon}" Width="18" Height="18" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <TextBlock Text="This PC" Opacity="0.6" FontSize="12" Margin="10,12,0,4" />
                        <ListView x:Name="DrivesList" SelectionMode="None" IsItemClickEnabled="True"
                                  ItemClick="Sidebar_ItemClick">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="10" Height="32">
                                        <Image Source="{Binding Icon}" Width="18" Height="18" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <StackPanel x:Name="DevicesSection" Visibility="Collapsed">
                            <TextBlock Text="Devices" Opacity="0.6" FontSize="12" Margin="10,12,0,4" />
                            <ListView x:Name="DevicesList" SelectionMode="None" IsItemClickEnabled="True"
                                      ItemClick="Sidebar_ItemClick">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="10" Height="32">
                                            <Image Source="{Binding Icon}" Width="18" Height="18" VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>

                        <TextBlock Text="Pinned" Opacity="0.6" FontSize="12" Margin="10,12,0,4" />
                        <ListView x:Name="PinnedList" SelectionMode="None" IsItemClickEnabled="True"
                                  ItemClick="Sidebar_ItemClick" RightTapped="PinnedList_RightTapped">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="10" Height="32">
                                        <Image Source="{Binding Icon}" Width="18" Height="18" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        <Button Click="AddLocation_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                Background="Transparent" BorderThickness="0" Padding="10,6" Margin="0,2,0,0"
                                ToolTipService.ToolTip="Add a folder, network share (\\server\share), or WSL path (\\wsl.localhost\distro)">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE710;" FontFamily="Segoe Fluent Icons" FontSize="14" />
                                <TextBlock Text="Add location" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <!-- Discreet entry: the only vault affordance shown while everything is locked. -->
                        <Button x:Name="VaultsLockedEntry" Click="VaultsLockedEntry_Click"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                Background="Transparent" BorderThickness="0" Padding="10,8" Margin="0,12,0,0"
                                ToolTipService.ToolTip="Open a vault">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE72E;" FontFamily="Segoe Fluent Icons" FontSize="16" />
                                <TextBlock Text="Vaults" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <!-- Full section: shown only once a vault is unlocked. -->
                        <StackPanel x:Name="VaultsSection" Visibility="Collapsed" Spacing="2">
                            <TextBlock Text="Vaults" Opacity="0.6" FontSize="12" Margin="10,12,0,4" />
                            <ListView x:Name="VaultsList" SelectionMode="None" IsItemClickEnabled="True"
                                      ItemClick="VaultsList_ItemClick" RightTapped="VaultsList_RightTapped">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="10" Height="32">
                                            <FontIcon Glyph="{Binding Glyph}" FontFamily="Segoe Fluent Icons"
                                                      FontSize="15" VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                            <Button Click="NewVault_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                    Background="Transparent" BorderThickness="0" Padding="10,6" Margin="0,2,0,0"
                                    ToolTipService.ToolTip="Create a new secure vault">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <FontIcon Glyph="&#xE710;" FontFamily="Segoe Fluent Icons" FontSize="14" />
                                    <TextBlock Text="New vault" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- Drag handle to resize the sidebar (nav) vs. the file pane -->
            <Border x:Name="SidebarSplitter" Grid.Column="1" Width="6" Margin="0,40,0,0" Background="Transparent"
                    ManipulationMode="TranslateX" ManipulationDelta="SidebarSplitter_ManipulationDelta"
                    ManipulationCompleted="SidebarSplitter_ManipulationCompleted" />

            <!-- Content (offset below the 40px title-bar drag region so the nav buttons are clickable) -->
            <Grid Grid.Column="2" Margin="0,40,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="48" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Folder tabs (Win11-style); each tab keeps its own navigation history -->
                <TabView x:Name="ExplorerTabs" Grid.Row="0" Margin="6,2,6,0"
                         IsAddTabButtonVisible="True" TabWidthMode="SizeToContent"
                         AddTabButtonClick="ExplorerTabs_AddClick"
                         SelectionChanged="ExplorerTabs_SelectionChanged"
                         TabCloseRequested="ExplorerTabs_CloseRequested" />

                <!-- Nav + address -->
                <Grid Grid.Row="1" Margin="8,0" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                        <Button x:Name="BackNav" Style="{StaticResource GlyphButton}" Width="36" Height="36" Click="NavBack_Click" ToolTipService.ToolTip="Back">
                            <FontIcon Glyph="&#xE72B;" FontFamily="Segoe Fluent Icons" FontSize="14" />
                        </Button>
                        <Button x:Name="FwdNav" Style="{StaticResource GlyphButton}" Width="36" Height="36" Click="NavForward_Click" ToolTipService.ToolTip="Forward">
                            <FontIcon Glyph="&#xE72A;" FontFamily="Segoe Fluent Icons" FontSize="14" />
                        </Button>
                        <Button x:Name="UpNav" Style="{StaticResource GlyphButton}" Width="36" Height="36" Click="NavUp_Click" ToolTipService.ToolTip="Up">
                            <FontIcon Glyph="&#xE70E;" FontFamily="Segoe Fluent Icons" FontSize="14" />
                        </Button>
                    </StackPanel>

                    <Border Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="6"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                            Margin="6,0,2,0" Padding="8,0" Height="34" VerticalAlignment="Center"
                            HorizontalAlignment="Stretch" DoubleTapped="PathBar_DoubleTapped">
                        <Grid>
                            <ScrollViewer x:Name="BreadcrumbScroller" HorizontalScrollMode="Auto"
                                          HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled">
                                <StackPanel x:Name="Breadcrumb" Orientation="Horizontal" VerticalAlignment="Center" />
                            </ScrollViewer>
                            <TextBox x:Name="AddressBox" Visibility="Collapsed" BorderThickness="0"
                                     Background="Transparent" VerticalAlignment="Center" KeyDown="AddressBox_KeyDown" />
                        </Grid>
                    </Border>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                        <Button x:Name="EditPathBtn" Style="{StaticResource GlyphButton}" Width="36" Height="36" Click="EditPath_Click" ToolTipService.ToolTip="Edit path">
                            <FontIcon Glyph="&#xE70F;" FontFamily="Segoe Fluent Icons" FontSize="14" />
                        </Button>
                        <Button x:Name="RefreshBtn" Style="{StaticResource GlyphButton}" Width="36" Height="36" Click="Refresh_Click" ToolTipService.ToolTip="Refresh">
                            <FontIcon Glyph="&#xE72C;" FontFamily="Segoe Fluent Icons" FontSize="14" />
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Command strip -->
                <Grid Grid.Row="2" Margin="10,4,10,8" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <Button Click="NewFolder_Click" ToolTipService.ToolTip="New folder">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE8F4;" FontFamily="Segoe Fluent Icons" FontSize="14" />
                            <TextBlock Text="New folder" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="HideFolderBtn" Click="HideFolder_Click" ToolTipService.ToolTip="Hide this folder (appears empty)">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon x:Name="HideFolderIcon" Glyph="&#xED1A;" FontFamily="Segoe Fluent Icons" FontSize="14" />
                            <TextBlock x:Name="HideFolderText" Text="Hide folder" />
                        </StackPanel>
                    </Button>
                    <AppBarSeparator />
                    <Button Click="ExplorerSlideshow_Click" ToolTipService.ToolTip="Slideshow of this folder's images">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE786;" FontFamily="Segoe Fluent Icons" FontSize="14" />
                            <TextBlock Text="Slideshow" />
                        </StackPanel>
                    </Button>
                    <Button Click="ExplorerCollage_Click" ToolTipService.ToolTip="Collage of this folder's images">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE8A9;" FontFamily="Segoe Fluent Icons" FontSize="14" />
                            <TextBlock Text="Collage" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="VaultShareBtn" Visibility="Collapsed" Click="VaultShare_Click"
                            ToolTipService.ToolTip="Share this vault with chosen friends">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE72D;" FontFamily="Segoe Fluent Icons" FontSize="14" />
                            <TextBlock Text="Share" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="VaultLockBtn" Visibility="Collapsed" Click="VaultLock_Click"
                            ToolTipService.ToolTip="Lock the open vault (re-encrypts and hides it)">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE72E;" FontFamily="Segoe Fluent Icons" FontSize="14" />
                            <TextBlock x:Name="VaultLockText" Text="Lock vault" />
                        </StackPanel>
                    </Button>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <AutoSuggestBox x:Name="SearchBox" Width="180" PlaceholderText="Search" QueryIcon="Find"
                                        VerticalAlignment="Center" TextChanged="SearchBox_TextChanged"
                                        ToolTipService.ToolTip="Search this folder" />
                        <ToggleButton x:Name="SearchRecursiveToggle" Click="SearchRecursive_Click"
                                      ToolTipService.ToolTip="Include subfolders in search">
                            <FontIcon Glyph="&#xE8B7;" FontFamily="Segoe Fluent Icons" FontSize="14" />
                        </ToggleButton>
                        <Button ToolTipService.ToolTip="Sort by">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE8CB;" FontFamily="Segoe Fluent Icons" FontSize="14" />
                                <TextBlock Text="Sort" />
                            </StackPanel>
                            <Button.Flyout>
                                <MenuFlyout>
                                    <RadioMenuFlyoutItem x:Name="SortName" Text="Name" GroupName="sortby" Click="Sort_Click" Tag="Name" />
                                    <RadioMenuFlyoutItem x:Name="SortDate" Text="Date modified" GroupName="sortby" Click="Sort_Click" Tag="Date" />
                                    <RadioMenuFlyoutItem x:Name="SortType" Text="Type" GroupName="sortby" Click="Sort_Click" Tag="Type" />
                                    <RadioMenuFlyoutItem x:Name="SortSize" Text="Size" GroupName="sortby" Click="Sort_Click" Tag="Size" />
                                    <MenuFlyoutSeparator />
                                    <RadioMenuFlyoutItem x:Name="SortAsc" Text="Ascending" GroupName="sortdir" Click="SortDir_Click" Tag="Asc" />
                                    <RadioMenuFlyoutItem x:Name="SortDesc" Text="Descending" GroupName="sortdir" Click="SortDir_Click" Tag="Desc" />
                                </MenuFlyout>
                            </Button.Flyout>
                        </Button>
                        <Button ToolTipService.ToolTip="Group by">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xF168;" FontFamily="Segoe Fluent Icons" FontSize="14" />
                                <TextBlock Text="Group" />
                            </StackPanel>
                            <Button.Flyout>
                                <MenuFlyout>
                                    <RadioMenuFlyoutItem x:Name="GroupNone" Text="(None)" GroupName="groupby" Click="Group_Click" Tag="None" />
                                    <RadioMenuFlyoutItem x:Name="GroupName" Text="Name" GroupName="groupby" Click="Group_Click" Tag="Name" />
                                    <RadioMenuFlyoutItem x:Name="GroupDate" Text="Date modified" GroupName="groupby" Click="Group_Click" Tag="Date" />
                                    <RadioMenuFlyoutItem x:Name="GroupType" Text="Type" GroupName="groupby" Click="Group_Click" Tag="Type" />
                                    <RadioMenuFlyoutItem x:Name="GroupSize" Text="Size" GroupName="groupby" Click="Group_Click" Tag="Size" />
                                </MenuFlyout>
                            </Button.Flyout>
                        </Button>
                        <Button ToolTipService.ToolTip="Recycle Bin">
                            <FontIcon Glyph="&#xE74D;" FontFamily="Segoe Fluent Icons" FontSize="14" />
                            <Button.Flyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem Text="Open Recycle Bin" Click="OpenRecycleBin_Click">
                                        <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE838;" FontFamily="Segoe Fluent Icons" /></MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutItem Text="Empty Recycle Bin…" Click="EmptyRecycleBin_Click">
                                        <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE74D;" FontFamily="Segoe Fluent Icons" /></MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                </MenuFlyout>
                            </Button.Flyout>
                        </Button>
                        <Button Click="Settings_Click" ToolTipService.ToolTip="Settings">
                            <FontIcon Glyph="&#xE713;" FontFamily="Segoe Fluent Icons" FontSize="14" />
                        </Button>
                        <Button x:Name="TerminalBtn" Visibility="Collapsed" Click="TerminalToggle_Click"
                                ToolTipService.ToolTip="Terminal (Developer Mode)">
                            <FontIcon Glyph="&#xE756;" FontFamily="Segoe Fluent Icons" FontSize="14" />
                        </Button>
                        <ToggleButton x:Name="ShowHiddenToggle" Click="ShowAppHidden_Click" ToolTipService.ToolTip="Show app-hidden folders">
                            <FontIcon Glyph="&#xE890;" FontFamily="Segoe Fluent Icons" FontSize="14" />
                        </ToggleButton>
                        <ToggleButton x:Name="ShowWindowsHiddenToggle" Click="ShowWindowsHidden_Click"
                                      ToolTipService.ToolTip="Show hidden items (this session only)">
                            <FontIcon Glyph="&#xED1A;" FontFamily="Segoe Fluent Icons" FontSize="14" />
                        </ToggleButton>
                        <Button x:Name="ViewModeBtn" ToolTipService.ToolTip="View">
                            <FontIcon Glyph="&#xE8A9;" FontFamily="Segoe Fluent Icons" FontSize="14" />
                            <Button.Flyout>
                                <MenuFlyout>
                                    <RadioMenuFlyoutItem x:Name="ViewLarge" Text="Large icons" GroupName="view" Click="ViewMode_Click" Tag="Large" />
                                    <RadioMenuFlyoutItem x:Name="ViewMedium" Text="Medium icons" GroupName="view" Click="ViewMode_Click" Tag="Medium" />
                                    <RadioMenuFlyoutItem x:Name="ViewSmall" Text="Small icons" GroupName="view" Click="ViewMode_Click" Tag="Small" />
                                    <RadioMenuFlyoutItem x:Name="ViewDetails" Text="Details" GroupName="view" Click="ViewMode_Click" Tag="Details" />
                                </MenuFlyout>
                            </Button.Flyout>
                        </Button>
                        <Slider x:Name="IconSizeSlider" Width="120" Minimum="48" Maximum="240" Value="110"
                                ValueChanged="IconSize_ValueChanged" VerticalAlignment="Center"
                                ToolTipService.ToolTip="Icon size" />
                    </StackPanel>
                </Grid>

                <!-- Content area -->
                <Grid Grid.Row="3" x:Name="ExplorerContentArea">
                    <GridView x:Name="ExplorerIconsView" Padding="12,0,12,12"
                              SelectionMode="Extended"
                              IsItemClickEnabled="True"
                              SelectionChanged="ExplorerSelection_Changed"
                              CanDragItems="True"
                              AllowDrop="True"
                              ItemClick="ExplorerItem_Click"
                              DoubleTapped="ExplorerItem_DoubleTapped"
                              DragItemsStarting="Explorer_DragItemsStarting"
                              DragOver="ExplorerList_DragOver"
                              Drop="ExplorerList_Drop"
                              RightTapped="ExplorerView_RightTapped"
                              ContainerContentChanging="ExplorerIcons_ContainerContentChanging">
                        <GridView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <ItemsWrapGrid Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </GridView.ItemsPanel>
                        <GridView.GroupStyle>
                            <GroupStyle>
                                <GroupStyle.HeaderTemplate>
                                    <DataTemplate>
                                        <Button Click="GroupHeader_Click" Background="Transparent" BorderThickness="0"
                                                Padding="4,10,8,4" Margin="0,4,0,0" HorizontalAlignment="Left"
                                                HorizontalContentAlignment="Left"
                                                ToolTipService.ToolTip="Expand / collapse">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <FontIcon Glyph="{Binding Glyph}" FontFamily="Segoe Fluent Icons" FontSize="12" VerticalAlignment="Center" />
                                                <TextBlock Text="{Binding HeaderText}" FontWeight="SemiBold" FontSize="14" Opacity="0.9" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Button>
                                    </DataTemplate>
                                </GroupStyle.HeaderTemplate>
                            </GroupStyle>
                        </GridView.GroupStyle>
                    </GridView>

                    <Grid x:Name="ExplorerDetailsView" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid Margin="58,0,24,0" Height="28" Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="90" />
                            </Grid.ColumnDefinitions>
                            <Button x:Name="HdrName" Tag="Name" Content="Name" Style="{StaticResource ColumnHeaderButton}"
                                    Click="SortHeader_Click" ToolTipService.ToolTip="Sort by name" />
                            <Button x:Name="HdrDate" Grid.Column="1" Tag="Date" Content="Date modified" Style="{StaticResource ColumnHeaderButton}"
                                    Click="SortHeader_Click" ToolTipService.ToolTip="Sort by date" />
                            <Button x:Name="HdrType" Grid.Column="2" Tag="Type" Content="Type" Style="{StaticResource ColumnHeaderButton}"
                                    Click="SortHeader_Click" ToolTipService.ToolTip="Sort by type" />
                            <Button x:Name="HdrSize" Grid.Column="3" Tag="Size" Content="Size" Style="{StaticResource ColumnHeaderButton}"
                                    HorizontalContentAlignment="Right" Click="SortHeader_Click" ToolTipService.ToolTip="Sort by size" />
                        </Grid>
                        <ListView x:Name="ExplorerDetailsList" Grid.Row="1" Padding="12,0,12,12"
                                  SelectionMode="Extended"
                                  IsItemClickEnabled="True"
                                  SelectionChanged="ExplorerSelection_Changed"
                                  CanDragItems="True"
                                  AllowDrop="True"
                                  ItemClick="ExplorerItem_Click"
                                  DoubleTapped="ExplorerItem_DoubleTapped"
                                  DragItemsStarting="Explorer_DragItemsStarting"
                                  DragOver="ExplorerList_DragOver"
                                  Drop="ExplorerList_Drop"
                                  RightTapped="ExplorerView_RightTapped"
                                  ContainerContentChanging="ExplorerIcons_ContainerContentChanging"
                                  ItemTemplate="{StaticResource ExplorerDetailsTemplate}">
                            <ListView.GroupStyle>
                                <GroupStyle>
                                    <GroupStyle.HeaderTemplate>
                                        <DataTemplate>
                                            <Button Click="GroupHeader_Click" Background="Transparent" BorderThickness="0"
                                                    Padding="8,8,8,4" Margin="38,4,0,0" HorizontalAlignment="Left"
                                                    HorizontalContentAlignment="Left"
                                                    ToolTipService.ToolTip="Expand / collapse">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <FontIcon Glyph="{Binding Glyph}" FontFamily="Segoe Fluent Icons" FontSize="12" VerticalAlignment="Center" />
                                                    <TextBlock Text="{Binding HeaderText}" FontWeight="SemiBold" FontSize="14" Opacity="0.9" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </GroupStyle.HeaderTemplate>
                                </GroupStyle>
                            </ListView.GroupStyle>
                        </ListView>
                    </Grid>

                    <!-- Hidden-folder placeholder -->
                    <StackPanel x:Name="HiddenFolderPlaceholder" Visibility="Collapsed"
                                HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                        <FontIcon Glyph="&#xED1A;" FontFamily="Segoe Fluent Icons" FontSize="48" Opacity="0.6" />
                        <TextBlock Text="This folder is hidden" FontSize="18" HorizontalAlignment="Center" />
                        <TextBlock Text="Its contents are concealed in Galileo." Opacity="0.7" HorizontalAlignment="Center" />
                        <Button Content="Unhide this folder" Click="UnhideCurrent_Click" HorizontalAlignment="Center" />
                    </StackPanel>

                    <StackPanel x:Name="ExplorerEmpty" Visibility="Collapsed"
                                HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10" MaxWidth="360">
                        <FontIcon Glyph="&#xE838;" FontFamily="Segoe Fluent Icons" FontSize="46" Opacity="0.4" HorizontalAlignment="Center" />
                        <TextBlock x:Name="ExplorerEmptyTitle" Text="This folder is empty" FontSize="18"
                                   FontWeight="SemiBold" HorizontalAlignment="Center" />
                        <TextBlock x:Name="ExplorerEmptySubtitle" Text="Drop files here, or use New folder to get started."
                                   Opacity="0.65" FontSize="13" TextWrapping="Wrap" TextAlignment="Center" HorizontalAlignment="Center" />
                        <Button Content="New folder" Click="NewFolder_Click" HorizontalAlignment="Center" Margin="0,4,0,0" />
                    </StackPanel>

                    <!-- Rubber-band (marquee) selection box, drawn over the icon view. -->
                    <Rectangle x:Name="MarqueeRect" Visibility="Collapsed" IsHitTestVisible="False"
                               HorizontalAlignment="Left" VerticalAlignment="Top"
                               Fill="{ThemeResource AccentFillColorDefaultBrush}" Opacity="0.20"
                               Stroke="{ThemeResource AccentFillColorDefaultBrush}" StrokeThickness="1" />
                </Grid>
            </Grid>

            <!-- Developer-mode embedded terminal: draggable splitter + pane (hidden by default) -->
            <Border x:Name="TerminalSplitter" Grid.Column="3" Visibility="Collapsed" Width="6" Margin="0,40,0,0"
                    Background="{ThemeResource CardStrokeColorDefaultBrush}" ManipulationMode="TranslateX"
                    ManipulationDelta="TerminalSplitter_ManipulationDelta" />
            <Grid x:Name="TerminalPane" Grid.Column="4" Visibility="Collapsed" Margin="0,40,0,0"
                  Background="{ThemeResource LayerFillColorAltBrush}"
                  BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Padding="8,6" ColumnDefinitions="*,Auto">
                    <ComboBox x:Name="ShellCombo" MinWidth="150" SelectionChanged="ShellCombo_SelectionChanged"
                              ToolTipService.ToolTip="Shell" />
                    <Button Grid.Column="1" Style="{StaticResource GlyphButton}" Click="TerminalClose_Click"
                            ToolTipService.ToolTip="Close terminal">
                        <FontIcon Glyph="&#xE8BB;" FontFamily="Segoe Fluent Icons" FontSize="13" />
                    </Button>
                </Grid>
                <WebView2 x:Name="TerminalWeb" Grid.Row="1" />
            </Grid>
        </Grid>

        <!-- ===================== Gallery ===================== -->
        <Grid x:Name="GalleryView" Visibility="Collapsed">
            <GridView x:Name="PhotoGrid"
                      Padding="24,56,24,32"
                      SelectionMode="None"
                      IsItemClickEnabled="True"
                      ItemClick="PhotoGrid_ItemClick"
                      SelectionChanged="PhotoGrid_SelectionChanged"
                      RightTapped="PhotoGrid_RightTapped"
                      ContainerContentChanging="PhotoGrid_ContainerContentChanging">
                <GridView.ItemTemplate>
                    <DataTemplate>
                        <Grid Width="196" Height="196" Margin="5"
                              CornerRadius="10" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                            <Image x:Name="PhotoThumb" Source="{Binding Thumbnail}" Stretch="UniformToFill" />
                            <Border Background="#B0000000" VerticalAlignment="Bottom" Padding="8,4">
                                <TextBlock Text="{Binding FileName}" FontSize="11"
                                           TextTrimming="CharacterEllipsis" Foreground="White" />
                            </Border>
                            <FontIcon Glyph="&#xE735;" FontFamily="Segoe Fluent Icons"
                                      Foreground="Gold" FontSize="16"
                                      HorizontalAlignment="Right" VerticalAlignment="Top" Margin="10"
                                      Visibility="{Binding FavoriteVisibility}" />
                            <Border Background="#CC000000" CornerRadius="10"
                                    Visibility="{Binding HiddenVisibility}">
                                <FontIcon Glyph="&#xED1A;" FontFamily="Segoe Fluent Icons"
                                          Foreground="White" FontSize="28"
                                          HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </Grid>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>

            <!-- Empty state -->
            <StackPanel x:Name="EmptyState" Visibility="Visible"
                        HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="14" MaxWidth="420">
                <FontIcon Glyph="&#xEB9F;" FontFamily="Segoe Fluent Icons" FontSize="56" Opacity="0.45" />
                <TextBlock Text="Your photos, beautifully" FontSize="24" FontWeight="SemiBold" HorizontalAlignment="Center" />
                <TextBlock Text="Open a file or folder, or drag photos anywhere onto this window."
                           Opacity="0.7" FontSize="14" TextWrapping="Wrap" TextAlignment="Center" />
                <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center" Margin="0,4,0,0">
                    <Button Content="Open file" Click="OpenFile_Click" Style="{StaticResource AccentButtonStyle}" />
                    <Button Content="Open folder" Click="OpenFolder_Click" />
                </StackPanel>
            </StackPanel>

            <!-- Floating gallery toolbar -->
            <Border HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,48,16,0"
                    CornerRadius="24" Padding="4" Background="{ThemeResource AcrylicInAppFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Orientation="Horizontal" Spacing="2">
                    <Button x:Name="OpenButton" Style="{StaticResource GlyphButton}"
                            ToolTipService.ToolTip="Open">
                        <FontIcon Glyph="&#xE8E5;" FontFamily="Segoe Fluent Icons" />
                        <Button.Flyout>
                            <MenuFlyout>
                                <MenuFlyoutItem Text="Open file…" Click="OpenFile_Click">
                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8E5;" FontFamily="Segoe Fluent Icons" /></MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem Text="Open folder…" Click="OpenFolder_Click">
                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE838;" FontFamily="Segoe Fluent Icons" /></MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>
                    <Button Style="{StaticResource GlyphButton}" Click="Slideshow_Click"
                            ToolTipService.ToolTip="Slideshow (F5)">
                        <FontIcon Glyph="&#xE786;" FontFamily="Segoe Fluent Icons" />
                    </Button>
                    <Button Style="{StaticResource GlyphButton}" Click="Collage_Click"
                            ToolTipService.ToolTip="Collage">
                        <FontIcon Glyph="&#xE8A9;" FontFamily="Segoe Fluent Icons" />
                    </Button>
                    <Button Style="{StaticResource GlyphButton}" Click="Settings_Click"
                            ToolTipService.ToolTip="Settings">
                        <FontIcon Glyph="&#xE713;" FontFamily="Segoe Fluent Icons" />
                    </Button>
                    <Button Style="{StaticResource GlyphButton}" ToolTipService.ToolTip="More">
                        <FontIcon Glyph="&#xE712;" FontFamily="Segoe Fluent Icons" />
                        <Button.Flyout>
                            <MenuFlyout>
                                <ToggleMenuFlyoutItem x:Name="SelectModeButton" Text="Select photos" Click="SelectMode_Click" />
                                <ToggleMenuFlyoutItem x:Name="HiddenAlbumButton" Text="Show Hidden album" Click="HiddenAlbum_Click" />
                                <ToggleMenuFlyoutItem x:Name="FavoritesFilterButton" Text="Favorites only" Click="FavoritesFilter_Click" />
                                <MenuFlyoutSeparator />
                                <MenuFlyoutItem Text="Close gallery" Click="CloseGallery_Click">
                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8BB;" FontFamily="Segoe Fluent Icons" /></MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ===================== Viewer ===================== -->
        <Grid x:Name="ViewerView" Visibility="Collapsed" Background="#FF101013"
              PointerMoved="ViewerView_PointerMoved">

            <Grid x:Name="ImageHost" Background="Transparent"
                  SizeChanged="ImageHost_SizeChanged"
                  PointerWheelChanged="ImageHost_PointerWheelChanged"
                  PointerPressed="ImageHost_PointerPressed"
                  PointerMoved="ImageHost_PointerMoved"
                  PointerReleased="ImageHost_PointerReleased"
                  DoubleTapped="ImageHost_DoubleTapped"
                  RightTapped="ImageHost_RightTapped">
                <Image x:Name="ViewerImage" Stretch="Uniform"
                       HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                       RenderTransformOrigin="0.5,0.5"
                       ImageOpened="ViewerImage_ImageOpened"
                       ImageFailed="ViewerImage_ImageFailed">
                    <Image.RenderTransform>
                        <CompositeTransform x:Name="ViewerTransform" />
                    </Image.RenderTransform>
                </Image>
            </Grid>

            <!-- Embedded media player (shown for video and audio files). Built-in volume is hidden —
                 the top-right speaker + slider handle it (speaker click toggles mute). -->
            <MediaPlayerElement x:Name="VideoPlayer" Visibility="Collapsed"
                                AreTransportControlsEnabled="True" AutoPlay="True" Stretch="Uniform">
                <MediaPlayerElement.TransportControls>
                    <MediaTransportControls IsVolumeButtonVisible="False" IsVolumeEnabled="False" />
                </MediaPlayerElement.TransportControls>
            </MediaPlayerElement>
            <!-- Live edit preview (Win2D frame-server output): shown while editing, over the player. -->
            <Image x:Name="EditPreviewImage" Visibility="Collapsed" Stretch="Uniform"
                   HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="0,0,360,96"
                   RenderTransformOrigin="0.5,0.5">
                <Image.RenderTransform>
                    <CompositeTransform x:Name="EditPreviewTransform" />
                </Image.RenderTransform>
            </Image>
            <!-- "Now playing" art for audio (no video frame); clicks pass through to the controls -->
            <StackPanel x:Name="AudioOverlay" Visibility="Collapsed" IsHitTestVisible="False"
                        HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="18">
                <Border x:Name="AudioArtHost" Visibility="Collapsed" Width="280" Height="280" CornerRadius="12">
                    <Image x:Name="AudioArt" Stretch="UniformToFill" />
                </Border>
                <FontIcon x:Name="AudioGlyph" Glyph="&#xE8D6;" FontFamily="Segoe Fluent Icons" FontSize="80" Foreground="White" Opacity="0.85" />
                <TextBlock x:Name="AudioTitle" Foreground="White" FontSize="18" MaxWidth="560"
                           HorizontalAlignment="Center" TextAlignment="Center" TextTrimming="CharacterEllipsis" />
            </StackPanel>
            <Border x:Name="VideoBackBar" Visibility="Collapsed"
                    HorizontalAlignment="Left" VerticalAlignment="Top" Margin="16,48,0,0"
                    CornerRadius="22" Padding="4" Background="{StaticResource PillBrush}">
                <Button Style="{StaticResource GlyphButton}" Foreground="White" Click="BackToGallery_Click"
                        ToolTipService.ToolTip="Back (Esc)">
                    <FontIcon Glyph="&#xE72B;" FontFamily="Segoe Fluent Icons" />
                </Button>
            </Border>
            <Border x:Name="VideoControlsBar" Visibility="Collapsed"
                    HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,48,16,0"
                    CornerRadius="24" Padding="4" Background="{StaticResource PillBrush}">
                <StackPanel Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                    <Button x:Name="VideoVolumeBtn" Style="{StaticResource GlyphButton}" Foreground="White"
                            Click="VideoVolume_Click" ToolTipService.ToolTip="Mute / unmute">
                        <FontIcon x:Name="VideoVolumeIcon" Glyph="&#xE995;" FontFamily="Segoe Fluent Icons" />
                    </Button>
                    <Slider x:Name="VideoVolumeSlider" Width="92" Minimum="0" Maximum="100" Value="100"
                            VerticalAlignment="Center" Margin="2,0,8,0" ValueChanged="VideoVolume_SliderChanged"
                            ToolTipService.ToolTip="Volume" />
                    <Button x:Name="VideoRepeatBtn" Style="{StaticResource GlyphButton}" Foreground="White"
                            Click="VideoRepeat_Click" ToolTipService.ToolTip="Repeat">
                        <FontIcon x:Name="VideoRepeatIcon" Glyph="&#xE8EE;" FontFamily="Segoe Fluent Icons" />
                    </Button>
                    <Button x:Name="VideoEditBtn" Style="{StaticResource GlyphButton}" Foreground="White"
                            Click="VideoEdit_Click" ToolTipService.ToolTip="Edit / export video">
                        <FontIcon Glyph="&#xE70F;" FontFamily="Segoe Fluent Icons" />
                    </Button>
                </StackPanel>
            </Border>

            <!-- Filmstrip timeline (scrub) — shown while editing, left of the editor panel -->
            <Border x:Name="EditTimeline" Visibility="Collapsed" Height="80"
                    HorizontalAlignment="Stretch" VerticalAlignment="Bottom" Margin="12,0,372,14"
                    CornerRadius="8" Background="#E6101013"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    SizeChanged="EditTimeline_SizeChanged"
                    PointerPressed="EditTimeline_PointerPressed"
                    PointerMoved="EditTimeline_PointerMoved"
                    PointerReleased="EditTimeline_PointerReleased">
                <Grid>
                    <Grid x:Name="EditFilmstrip" />
                    <!-- Kept region (between trim start and end) + start/end marks -->
                    <Border x:Name="EditKeptRegion" Background="#335AD19A" HorizontalAlignment="Left"
                            IsHitTestVisible="False" Visibility="Collapsed">
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="EditKeptShift" />
                        </Border.RenderTransform>
                    </Border>
                    <Border x:Name="EditStartMark" Width="3" Background="#FF5AD19A" HorizontalAlignment="Left"
                            IsHitTestVisible="False" Visibility="Collapsed">
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="EditStartShift" />
                        </Border.RenderTransform>
                    </Border>
                    <Border x:Name="EditEndMark" Width="3" Background="#FFF0934E" HorizontalAlignment="Left"
                            IsHitTestVisible="False" Visibility="Collapsed">
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="EditEndShift" />
                        </Border.RenderTransform>
                    </Border>
                    <Border x:Name="EditPlayhead" Width="2.5" Background="#FF6EA8FF"
                            HorizontalAlignment="Left" IsHitTestVisible="False">
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="EditPlayheadShift" />
                        </Border.RenderTransform>
                    </Border>
                </Grid>
            </Border>

            <!-- ===================== Video editor panel (FFmpeg-powered) ===================== -->
            <Border x:Name="VideoEditorPanel" Visibility="Collapsed"
                    HorizontalAlignment="Right" VerticalAlignment="Stretch" Width="360"
                    Background="{ThemeResource AcrylicInAppFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1,0,0,0">
                <Grid RowDefinitions="Auto,*,Auto">
                    <!-- Header -->
                    <Grid Grid.Row="0" Padding="16,12" ColumnDefinitions="*,Auto"
                          Background="{ThemeResource LayerFillColorAltBrush}">
                        <TextBlock Text="Edit video" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <Button Grid.Column="1" Style="{StaticResource GlyphButton}" Click="CloseVideoEditor_Click"
                                ToolTipService.ToolTip="Close">
                            <FontIcon Glyph="&#xE711;" FontFamily="Segoe Fluent Icons" FontSize="14" />
                        </Button>
                    </Grid>

                    <ScrollViewer Grid.Row="1" Padding="16,8,16,8" VerticalScrollBarVisibility="Auto">
                        <StackPanel Spacing="18">

                            <!-- Trim -->
                            <StackPanel Spacing="8">
                                <TextBlock Text="TRIM" Style="{StaticResource SettingSectionHeader}" />
                                <TextBlock x:Name="EditTrimText" Text="Whole clip" Opacity="0.8" FontSize="13" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Content="Set start" Click="EditSetStart_Click" />
                                    <Button Content="Set end" Click="EditSetEnd_Click" />
                                    <Button Content="Reset" Click="EditResetTrim_Click" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Content="Add as segment" Click="EditAddSegment_Click" />
                                    <Button Content="Clear segments" Click="EditClearSegments_Click" />
                                </StackPanel>
                                <TextBlock x:Name="EditSegmentsText" Text="" Opacity="0.7" FontSize="12" TextWrapping="Wrap" />
                            </StackPanel>

                            <!-- Transform -->
                            <StackPanel Spacing="8">
                                <TextBlock Text="TRANSFORM" Style="{StaticResource SettingSectionHeader}" />
                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <Button Click="EditRotateLeft_Click" ToolTipService.ToolTip="Rotate left">
                                        <FontIcon Glyph="&#xE7AD;" FontFamily="Segoe Fluent Icons" FontSize="14" />
                                    </Button>
                                    <Button Click="EditRotateRight_Click" ToolTipService.ToolTip="Rotate right">
                                        <FontIcon Glyph="&#xE7AE;" FontFamily="Segoe Fluent Icons" FontSize="14" />
                                    </Button>
                                    <TextBlock x:Name="EditRotateText" Text="0°" VerticalAlignment="Center" Opacity="0.8" />
                                </StackPanel>
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                    <ToggleSwitch x:Name="EditFlipHSwitch" Header="Flip horizontal" />
                                    <ToggleSwitch x:Name="EditFlipVSwitch" Grid.Column="1" Header="Flip vertical" />
                                </Grid>
                                <TextBlock Text="Crop margins (px): left / top / right / bottom" FontSize="12" Opacity="0.7" />
                                <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="6">
                                    <NumberBox x:Name="EditCropL" Value="0" Minimum="0" SpinButtonPlacementMode="Hidden" />
                                    <NumberBox x:Name="EditCropT" Grid.Column="1" Value="0" Minimum="0" SpinButtonPlacementMode="Hidden" />
                                    <NumberBox x:Name="EditCropR" Grid.Column="2" Value="0" Minimum="0" SpinButtonPlacementMode="Hidden" />
                                    <NumberBox x:Name="EditCropB" Grid.Column="3" Value="0" Minimum="0" SpinButtonPlacementMode="Hidden" />
                                </Grid>
                                <TextBlock Text="Resize (px): width × height (0 = keep)" FontSize="12" Opacity="0.7" />
                                <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="6">
                                    <NumberBox x:Name="EditResizeW" Value="0" Minimum="0" SpinButtonPlacementMode="Hidden" />
                                    <TextBlock Grid.Column="1" Text="×" VerticalAlignment="Center" />
                                    <NumberBox x:Name="EditResizeH" Grid.Column="2" Value="0" Minimum="0" SpinButtonPlacementMode="Hidden" />
                                </Grid>
                            </StackPanel>

                            <!-- Filters -->
                            <StackPanel Spacing="8">
                                <TextBlock Text="FILTERS" Style="{StaticResource SettingSectionHeader}" />
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                    <ToggleSwitch x:Name="EditDeinterlace" Header="Deinterlace" />
                                    <ToggleSwitch x:Name="EditDenoise" Grid.Column="1" Header="Denoise" />
                                </Grid>
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                    <ToggleSwitch x:Name="EditSharpen" Header="Sharpen" />
                                    <ToggleSwitch x:Name="EditStabilize" Grid.Column="1" Header="Stabilize" />
                                </Grid>
                                <TextBlock Text="Brightness" FontSize="12" Opacity="0.7" />
                                <Slider x:Name="EditBrightness" Minimum="-1" Maximum="1" StepFrequency="0.05" Value="0" />
                                <TextBlock Text="Contrast" FontSize="12" Opacity="0.7" />
                                <Slider x:Name="EditContrast" Minimum="0" Maximum="2" StepFrequency="0.05" Value="1" />
                                <TextBlock Text="Saturation" FontSize="12" Opacity="0.7" />
                                <Slider x:Name="EditSaturation" Minimum="0" Maximum="3" StepFrequency="0.05" Value="1" />
                            </StackPanel>

                            <!-- Playback / audio -->
                            <StackPanel Spacing="8">
                                <TextBlock Text="SPEED &amp; AUDIO" Style="{StaticResource SettingSectionHeader}" />
                                <TextBlock Text="Speed (×)" FontSize="12" Opacity="0.7" />
                                <Slider x:Name="EditSpeed" Minimum="0.25" Maximum="4" StepFrequency="0.05" Value="1" />
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                    <TextBlock Text="Frame rate" VerticalAlignment="Center" />
                                    <NumberBox x:Name="EditFps" Grid.Column="1" Value="0" Minimum="0" SpinButtonPlacementMode="Hidden"
                                               PlaceholderText="0 = keep" />
                                </Grid>
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                    <TextBlock Text="Audio" VerticalAlignment="Center" />
                                    <ComboBox x:Name="EditAudioCombo" Grid.Column="1" HorizontalAlignment="Stretch" SelectedIndex="0">
                                        <ComboBoxItem Content="Keep" />
                                        <ComboBoxItem Content="Re-encode AAC" />
                                        <ComboBoxItem Content="Re-encode MP3" />
                                        <ComboBoxItem Content="Mute (no audio)" />
                                    </ComboBox>
                                </Grid>
                            </StackPanel>

                            <!-- Output -->
                            <StackPanel Spacing="8">
                                <TextBlock Text="OUTPUT" Style="{StaticResource SettingSectionHeader}" />
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                    <TextBlock Text="Format" VerticalAlignment="Center" />
                                    <ComboBox x:Name="EditContainerCombo" Grid.Column="1" HorizontalAlignment="Stretch"
                                              SelectedIndex="0" SelectionChanged="EditContainer_SelectionChanged">
                                        <ComboBoxItem Content="MP4" />
                                        <ComboBoxItem Content="MKV" />
                                        <ComboBoxItem Content="MPEG-TS" />
                                        <ComboBoxItem Content="Animated GIF" />
                                    </ComboBox>
                                </Grid>
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                    <TextBlock Text="Codec" VerticalAlignment="Center" />
                                    <ComboBox x:Name="EditCodecCombo" Grid.Column="1" HorizontalAlignment="Stretch" SelectedIndex="0" />
                                </Grid>
                                <TextBlock Text="Quality (CRF — lower is better)" FontSize="12" Opacity="0.7" />
                                <Slider x:Name="EditCrf" Minimum="0" Maximum="51" StepFrequency="1" Value="21" />
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                    <TextBlock Text="Preset" VerticalAlignment="Center" />
                                    <ComboBox x:Name="EditPresetCombo" Grid.Column="1" HorizontalAlignment="Stretch" SelectedIndex="2">
                                        <ComboBoxItem Content="ultrafast" />
                                        <ComboBoxItem Content="veryfast" />
                                        <ComboBoxItem Content="medium" />
                                        <ComboBoxItem Content="slow" />
                                        <ComboBoxItem Content="veryslow" />
                                    </ComboBox>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Footer -->
                    <StackPanel Grid.Row="2" Padding="16,12" Spacing="8"
                                Background="{ThemeResource LayerFillColorAltBrush}">
                        <TextBlock x:Name="EditorStatus" Text="" FontSize="12" Opacity="0.75" TextWrapping="Wrap" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="Save frame" Click="EditSaveFrame_Click" />
                            <Button Content="Export…" Click="EditExport_Click" Style="{StaticResource AccentButtonStyle}" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Eye obscure: plain black curtain -->
            <Grid x:Name="ObscureOverlay" Visibility="Collapsed" Background="Black" />

            <!-- Floating chrome that auto-hides -->
            <Grid x:Name="ViewerChrome">

                <!-- Top-left: back -->
                <Border HorizontalAlignment="Left" VerticalAlignment="Top" Margin="16,48,0,0"
                        CornerRadius="22" Padding="4" Background="{StaticResource PillBrush}">
                    <Button Style="{StaticResource GlyphButton}" Foreground="White" Click="BackToGallery_Click"
                            ToolTipService.ToolTip="Back to gallery (Esc)">
                        <FontIcon Glyph="&#xE72B;" FontFamily="Segoe Fluent Icons" />
                    </Button>
                </Border>

                <!-- Top-right: actions -->
                <Border HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,48,16,0"
                        CornerRadius="24" Padding="4" Background="{StaticResource PillBrush}">
                    <StackPanel Orientation="Horizontal" Spacing="2">
                        <Button x:Name="FavoriteButton" Style="{StaticResource GlyphButton}" Foreground="White"
                                Click="Favorite_Click" ToolTipService.ToolTip="Favorite">
                            <FontIcon x:Name="FavoriteIcon" Glyph="&#xE734;" FontFamily="Segoe Fluent Icons" />
                        </Button>
                        <Button x:Name="EyeButton" Style="{StaticResource GlyphButton}" Foreground="White"
                                Click="Eye_Click" ToolTipService.ToolTip="Hide / reveal (H)">
                            <FontIcon x:Name="EyeIcon" Glyph="&#xE890;" FontFamily="Segoe Fluent Icons" />
                            <Button.Flyout>
                                <MenuFlyout Placement="Bottom">
                                    <MenuFlyoutItem Text="Hide / reveal in view (H)" Click="EyeObscure_Click">
                                        <MenuFlyoutItem.Icon><FontIcon Glyph="&#xED1A;" FontFamily="Segoe Fluent Icons" /></MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutItem Text="Hide permanently (Hidden album)" Click="EyeHidePermanent_Click">
                                        <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE890;" FontFamily="Segoe Fluent Icons" /></MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                </MenuFlyout>
                            </Button.Flyout>
                        </Button>
                        <Button Style="{StaticResource GlyphButton}" Foreground="White" Click="Rotate_Click"
                                ToolTipService.ToolTip="Rotate (R)">
                            <FontIcon Glyph="&#xE7AD;" FontFamily="Segoe Fluent Icons" />
                        </Button>
                        <Button Style="{StaticResource GlyphButton}" Foreground="White" Click="Edit_Click"
                                ToolTipService.ToolTip="Edit image">
                            <FontIcon Glyph="&#xE70F;" FontFamily="Segoe Fluent Icons" />
                        </Button>
                        <Button Style="{StaticResource GlyphButton}" Foreground="White" Click="Info_Click"
                                ToolTipService.ToolTip="Photo info">
                            <FontIcon Glyph="&#xE946;" FontFamily="Segoe Fluent Icons" />
                        </Button>
                        <Button Style="{StaticResource GlyphButton}" Foreground="White" Click="Reveal_Click"
                                ToolTipService.ToolTip="Reveal in Explorer">
                            <FontIcon Glyph="&#xEC50;" FontFamily="Segoe Fluent Icons" />
                        </Button>
                        <Button Style="{StaticResource GlyphButton}" Foreground="White" Click="Delete_Click"
                                ToolTipService.ToolTip="Delete">
                            <FontIcon Glyph="&#xE74D;" FontFamily="Segoe Fluent Icons" />
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Bottom-centre: navigation & zoom -->
                <Border HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,28"
                        CornerRadius="26" Padding="6" Background="{StaticResource PillBrush}">
                    <StackPanel Orientation="Horizontal" Spacing="2">
                        <Button Style="{StaticResource GlyphButton}" Foreground="White" Click="Prev_Click"
                                ToolTipService.ToolTip="Previous">
                            <FontIcon Glyph="&#xE76B;" FontFamily="Segoe Fluent Icons" />
                        </Button>
                        <Button Style="{StaticResource GlyphButton}" Foreground="White" Click="ZoomOut_Click"
                                ToolTipService.ToolTip="Zoom out">
                            <FontIcon Glyph="&#xE71F;" FontFamily="Segoe Fluent Icons" />
                        </Button>
                        <Button Style="{StaticResource GlyphButton}" Foreground="White" Click="Fit_Click"
                                ToolTipService.ToolTip="Fit (0)">
                            <FontIcon Glyph="&#xE9A6;" FontFamily="Segoe Fluent Icons" />
                        </Button>
                        <Button Style="{StaticResource GlyphButton}" Foreground="White" Click="ZoomIn_Click"
                                ToolTipService.ToolTip="Zoom in">
                            <FontIcon Glyph="&#xE8A3;" FontFamily="Segoe Fluent Icons" />
                        </Button>
                        <Button Style="{StaticResource GlyphButton}" Foreground="White" Click="Next_Click"
                                ToolTipService.ToolTip="Next">
                            <FontIcon Glyph="&#xE76C;" FontFamily="Segoe Fluent Icons" />
                        </Button>
                        <Border Width="1" Margin="6,8" Background="#33FFFFFF" />
                        <Button Style="{StaticResource GlyphButton}" Foreground="White" Click="Slideshow_Click"
                                ToolTipService.ToolTip="Slideshow (F5)">
                            <FontIcon Glyph="&#xE786;" FontFamily="Segoe Fluent Icons" />
                        </Button>
                        <Button Style="{StaticResource GlyphButton}" Foreground="White" Click="FullScreen_Click"
                                ToolTipService.ToolTip="Full screen (F11)">
                            <FontIcon Glyph="&#xE740;" FontFamily="Segoe Fluent Icons" />
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Metadata panel -->
            <Border x:Name="InfoPanel" Visibility="Collapsed"
                    HorizontalAlignment="Right" VerticalAlignment="Top" Margin="16,104,16,0"
                    Width="330" Padding="18" CornerRadius="12"
                    Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="6">
                    <TextBlock Text="Photo info" FontWeight="SemiBold" FontSize="16" />
                    <TextBlock x:Name="InfoText" TextWrapping="Wrap" FontSize="13" Opacity="0.9" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- ===================== Image editor ===================== -->
        <Grid x:Name="EditorView" Visibility="Collapsed" Background="#FF0B0B0E">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="300" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Edit image" Margin="20,44,20,10"
                       FontSize="18" FontWeight="SemiBold" Foreground="White" />

            <!-- Canvas + overlays -->
            <Grid Grid.Row="1" Grid.Column="0" x:Name="EditCanvasHost" Margin="12,0,0,12"
                  SizeChanged="EditCanvasHost_SizeChanged">
                <!-- CanvasControl + markup are drawn in code-behind (Win2D/Ink controls in XAML crash the markup compiler) -->
                <Canvas x:Name="OverlayCanvas" Background="Transparent" IsHitTestVisible="False"
                        PointerPressed="Overlay_PointerPressed" PointerMoved="Overlay_PointerMoved"
                        PointerReleased="Overlay_PointerReleased" DoubleTapped="Overlay_DoubleTapped" />
            </Grid>

            <!-- Tools rail -->
            <Border Grid.Row="1" Grid.Column="1" Background="#FF15151B"
                    BorderBrush="#22FFFFFF" BorderThickness="1,0,0,0">
                <ScrollViewer>
                    <StackPanel Padding="16" Spacing="20">

                        <!-- Transform -->
                        <StackPanel Spacing="8">
                            <TextBlock Text="TRANSFORM" Foreground="#99FFFFFF" FontSize="11" FontWeight="SemiBold" />
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Button Content="↺" FontSize="16" MinWidth="40" Click="RotateCcw_Click" ToolTipService.ToolTip="Rotate left" />
                                <Button Content="↻" FontSize="16" MinWidth="40" Click="RotateCw_Click" ToolTipService.ToolTip="Rotate right" />
                                <Button Content="↔" FontSize="16" MinWidth="40" Click="FlipH_Click" ToolTipService.ToolTip="Flip horizontal" />
                                <Button Content="↕" FontSize="16" MinWidth="40" Click="FlipV_Click" ToolTipService.ToolTip="Flip vertical" />
                            </StackPanel>
                            <TextBlock Text="Crop" Foreground="White" FontSize="13" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <ComboBox x:Name="CropAspectCombo" MinWidth="118" SelectionChanged="CropAspect_Changed">
                                    <ComboBoxItem Content="Free" IsSelected="True" />
                                    <ComboBoxItem Content="Original" />
                                    <ComboBoxItem Content="1:1" />
                                    <ComboBoxItem Content="4:3" />
                                    <ComboBoxItem Content="3:2" />
                                    <ComboBoxItem Content="16:9" />
                                </ComboBox>
                                <Button Content="Crop" Click="CropEnter_Click" ToolTipService.ToolTip="Draw / move a crop region" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Content="Apply" Click="CropApply_Click" ToolTipService.ToolTip="Preview the crop on the image" />
                                <Button Content="Reset" Click="CropReset_Click" ToolTipService.ToolTip="Clear the crop" />
                            </StackPanel>
                            <TextBlock Text="Straighten" Foreground="White" FontSize="13" />
                            <Slider x:Name="StraightenSlider" Minimum="-45" Maximum="45" Value="0"
                                    StepFrequency="1" ValueChanged="Straighten_Changed" />
                        </StackPanel>

                        <!-- Adjust -->
                        <StackPanel Spacing="6">
                            <TextBlock Text="ADJUST" Foreground="#99FFFFFF" FontSize="11" FontWeight="SemiBold" />
                            <TextBlock Text="Exposure" Foreground="White" FontSize="12" />
                            <Slider x:Name="ExposureSlider" Minimum="-100" Maximum="100" Value="0" ValueChanged="Adjust_Changed" />
                            <TextBlock Text="Brightness" Foreground="White" FontSize="12" />
                            <Slider x:Name="BrightnessSlider" Minimum="-100" Maximum="100" Value="0" ValueChanged="Adjust_Changed" />
                            <TextBlock Text="Contrast" Foreground="White" FontSize="12" />
                            <Slider x:Name="ContrastSlider" Minimum="-100" Maximum="100" Value="0" ValueChanged="Adjust_Changed" />
                            <TextBlock Text="Saturation" Foreground="White" FontSize="12" />
                            <Slider x:Name="SaturationSlider" Minimum="-100" Maximum="100" Value="0" ValueChanged="Adjust_Changed" />
                            <TextBlock Text="Temperature" Foreground="White" FontSize="12" />
                            <Slider x:Name="TemperatureSlider" Minimum="-100" Maximum="100" Value="0" ValueChanged="Adjust_Changed" />
                            <TextBlock Text="Tint" Foreground="White" FontSize="12" />
                            <Slider x:Name="TintSlider" Minimum="-100" Maximum="100" Value="0" ValueChanged="Adjust_Changed" />
                            <TextBlock Text="Sharpness" Foreground="White" FontSize="12" />
                            <Slider x:Name="SharpnessSlider" Minimum="0" Maximum="100" Value="0" ValueChanged="Adjust_Changed" />
                        </StackPanel>

                        <!-- Filters -->
                        <StackPanel Spacing="8">
                            <TextBlock Text="FILTERS" Foreground="#99FFFFFF" FontSize="11" FontWeight="SemiBold" />
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Button Content="None" Click="Filter_Click" Tag="None" />
                                <Button Content="Auto" Click="Filter_Click" Tag="Auto" />
                                <Button Content="B&amp;W" Click="Filter_Click" Tag="BlackWhite" />
                                <Button Content="Sepia" Click="Filter_Click" Tag="Sepia" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Button Content="Vivid" Click="Filter_Click" Tag="Vivid" />
                                <Button Content="Warm" Click="Filter_Click" Tag="Warm" />
                                <Button Content="Cool" Click="Filter_Click" Tag="Cool" />
                                <Button Content="Invert" Click="Filter_Click" Tag="Invert" />
                            </StackPanel>
                        </StackPanel>

                        <!-- Markup -->
                        <StackPanel Spacing="8">
                            <TextBlock Text="MARKUP" Foreground="#99FFFFFF" FontSize="11" FontWeight="SemiBold" />
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Button Content="Pen" Click="MarkupTool_Click" Tag="Pen" />
                                <Button Content="Text" Click="MarkupTool_Click" Tag="Text" />
                                <Button Content="Rect" Click="MarkupTool_Click" Tag="Rectangle" />
                                <Button Content="Ellipse" Click="MarkupTool_Click" Tag="Ellipse" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Button Content="Line" Click="MarkupTool_Click" Tag="Line" />
                                <Button Content="Arrow" Click="MarkupTool_Click" Tag="Arrow" />
                                <Button Content="Done" Click="MarkupNone_Click" ToolTipService.ToolTip="Stop drawing shapes" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <ComboBox x:Name="MarkupColorCombo" MinWidth="110" SelectedIndex="0">
                                    <ComboBoxItem Content="Red" />
                                    <ComboBoxItem Content="Yellow" />
                                    <ComboBoxItem Content="Lime" />
                                    <ComboBoxItem Content="White" />
                                    <ComboBoxItem Content="Black" />
                                </ComboBox>
                                <Button Content="Clear" Click="MarkupClear_Click" ToolTipService.ToolTip="Clear shapes &amp; ink" />
                            </StackPanel>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Command bar -->
            <Border Grid.Row="2" Grid.ColumnSpan="2" Background="#FF15151B"
                    BorderBrush="#22FFFFFF" BorderThickness="0,1,0,0" Padding="12,8">
                <Grid>
                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Left">
                        <Button Style="{StaticResource GlyphButton}" Foreground="White" Click="EditUndo_Click" ToolTipService.ToolTip="Undo">
                            <FontIcon Glyph="&#xE7A7;" FontFamily="Segoe Fluent Icons" />
                        </Button>
                        <Button Style="{StaticResource GlyphButton}" Foreground="White" Click="EditRedo_Click" ToolTipService.ToolTip="Redo">
                            <FontIcon Glyph="&#xE7A6;" FontFamily="Segoe Fluent Icons" />
                        </Button>
                        <Button Content="Reset" Click="EditReset_Click" VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                        <Button Content="Cancel" Click="EditCancel_Click" />
                        <Button Content="Save Copy" Click="SaveCopy_Click" />
                        <Button Content="Overwrite" Click="SaveOverwrite_Click" />
                        <Button Content="Save As" Click="SaveAs_Click" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ===================== Collage ===================== -->
        <Grid x:Name="CollageView" Visibility="Collapsed" Background="#FF101013">
            <Canvas x:Name="CollageCanvas" SizeChanged="CollageCanvas_SizeChanged" />

            <!-- Floating collage controls -->
            <Border HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,28"
                    CornerRadius="26" Padding="6" Background="{StaticResource PillBrush}">
                <StackPanel Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                    <Button Style="{StaticResource GlyphButton}" Foreground="White" Click="CollageBack_Click"
                            ToolTipService.ToolTip="Back to gallery (Esc)">
                        <FontIcon Glyph="&#xE72B;" FontFamily="Segoe Fluent Icons" />
                    </Button>
                    <Border Width="1" Margin="6,8" Background="#33FFFFFF" />
                    <Button Style="{StaticResource GlyphButton}" Foreground="White" Click="CollageFewer_Click"
                            ToolTipService.ToolTip="Fewer photos">
                        <FontIcon Glyph="&#xE738;" FontFamily="Segoe Fluent Icons" />
                    </Button>
                    <TextBlock x:Name="CollageCountText" Foreground="White" VerticalAlignment="Center"
                               MinWidth="64" TextAlignment="Center" Text="0 photos" />
                    <Button Style="{StaticResource GlyphButton}" Foreground="White" Click="CollageMore_Click"
                            ToolTipService.ToolTip="More photos">
                        <FontIcon Glyph="&#xE710;" FontFamily="Segoe Fluent Icons" />
                    </Button>
                    <Border Width="1" Margin="6,8" Background="#33FFFFFF" />
                    <Button Style="{StaticResource GlyphButton}" Foreground="White" ToolTipService.ToolTip="Layout">
                        <FontIcon Glyph="&#xE71D;" FontFamily="Segoe Fluent Icons" />
                        <Button.Flyout>
                            <MenuFlyout>
                                <RadioMenuFlyoutItem x:Name="PresetJustified" Text="Justified" GroupName="preset"
                                                     IsChecked="True" Click="CollagePreset_Click" Tag="Justified" />
                                <RadioMenuFlyoutItem x:Name="PresetGrid" Text="Grid" GroupName="preset"
                                                     Click="CollagePreset_Click" Tag="Grid" />
                                <RadioMenuFlyoutItem x:Name="PresetHero" Text="Hero" GroupName="preset"
                                                     Click="CollagePreset_Click" Tag="Hero" />
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>
                    <Button Style="{StaticResource GlyphButton}" Foreground="White" Click="CollageShuffle_Click"
                            ToolTipService.ToolTip="Shuffle">
                        <FontIcon Glyph="&#xE8B1;" FontFamily="Segoe Fluent Icons" />
                    </Button>
                    <Button Style="{StaticResource GlyphButton}" Foreground="White" Click="CollageSave_Click"
                            ToolTipService.ToolTip="Save collage…">
                        <FontIcon Glyph="&#xE74E;" FontFamily="Segoe Fluent Icons" />
                    </Button>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ===================== Settings overlay ===================== -->
        <Grid x:Name="SettingsOverlay" Visibility="Collapsed" Background="#AA000000"
              Tapped="SettingsScrim_Tapped">
            <Border x:Name="SettingsCard" Width="540" MaxHeight="760"
                    VerticalAlignment="Center" HorizontalAlignment="Center" RenderTransformOrigin="0.5,0.5"
                    Background="{ThemeResource SolidBackgroundFillColorBaseBrush}" CornerRadius="14"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    Tapped="SettingsCard_Tapped">
                <Border.RenderTransform>
                    <CompositeTransform x:Name="SettingsCardTransform" />
                </Border.RenderTransform>

                <!-- Shared look for every setting row: label/description left, control right. -->
                <Border.Resources>
                    <Style x:Key="SettingRow" TargetType="Grid">
                        <Setter Property="ColumnSpacing" Value="16" />
                    </Style>
                    <Style x:Key="SettingControl" TargetType="ComboBox">
                        <Setter Property="VerticalAlignment" Value="Center" />
                        <Setter Property="MinWidth" Value="170" />
                    </Style>
                    <Style x:Key="SettingDesc" TargetType="TextBlock">
                        <Setter Property="Opacity" Value="0.6" />
                        <Setter Property="FontSize" Value="12" />
                        <Setter Property="TextWrapping" Value="Wrap" />
                        <Setter Property="Margin" Value="0,2,0,0" />
                    </Style>
                    <Style x:Key="SettingCard" TargetType="Border">
                        <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
                        <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
                        <Setter Property="BorderThickness" Value="1" />
                        <Setter Property="CornerRadius" Value="8" />
                        <Setter Property="Padding" Value="16" />
                    </Style>
                </Border.Resources>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Grid Padding="24,20,16,12">
                        <TextBlock Text="Settings" FontSize="22" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <Button Style="{StaticResource GlyphButton}" Click="SettingsClose_Click"
                                HorizontalAlignment="Right" ToolTipService.ToolTip="Close without saving">
                            <FontIcon Glyph="&#xE8BB;" FontFamily="Segoe Fluent Icons" FontSize="14" />
                        </Button>
                    </Grid>

                    <!-- Body -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" VerticalScrollMode="Auto"
                                  Padding="24,0,20,4">
                        <StackPanel Spacing="20">

                            <!-- Appearance -->
                            <StackPanel Spacing="8">
                                <TextBlock Text="APPEARANCE" Style="{StaticResource SettingSectionHeader}" />
                                <Border Style="{StaticResource SettingCard}">
                                    <StackPanel Spacing="16">
                                        <Grid Style="{StaticResource SettingRow}" ColumnDefinitions="*,Auto">
                                            <TextBlock Text="Theme" VerticalAlignment="Center" />
                                            <ComboBox Grid.Column="1" x:Name="ThemeCombo" Style="{StaticResource SettingControl}"
                                                      SelectionChanged="ThemeCombo_SelectionChanged">
                                                <ComboBoxItem Content="System default" />
                                                <ComboBoxItem Content="Light" />
                                                <ComboBoxItem Content="Dark" />
                                                <ComboBoxItem Content="Terminal (green)" />
                                                <ComboBoxItem Content="Gray" />
                                            </ComboBox>
                                        </Grid>
                                        <Grid Style="{StaticResource SettingRow}" ColumnDefinitions="*,Auto">
                                            <TextBlock Text="Default icon size" VerticalAlignment="Center" />
                                            <ComboBox Grid.Column="1" x:Name="IconSizeCombo" Style="{StaticResource SettingControl}"
                                                      SelectionChanged="IconSizeCombo_SelectionChanged">
                                                <ComboBoxItem Content="Small" />
                                                <ComboBoxItem Content="Medium" />
                                                <ComboBoxItem Content="Large" />
                                            </ComboBox>
                                        </Grid>
                                        <Grid Style="{StaticResource SettingRow}" ColumnDefinitions="*,Auto">
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="Folder content previews" />
                                                <TextBlock Text="Paint a preview of the first image inside a folder onto its icon."
                                                           Style="{StaticResource SettingDesc}" />
                                            </StackPanel>
                                            <ToggleSwitch Grid.Column="1" x:Name="FolderPreviewSwitch" Toggled="FolderPreviewSwitch_Toggled" />
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- Explorer -->
                            <StackPanel Spacing="8">
                                <TextBlock Text="EXPLORER" Style="{StaticResource SettingSectionHeader}" />
                                <Border Style="{StaticResource SettingCard}">
                                    <StackPanel Spacing="16">
                                        <Grid Style="{StaticResource SettingRow}" ColumnDefinitions="*,Auto">
                                            <TextBlock Text="Open items with" VerticalAlignment="Center" />
                                            <ComboBox Grid.Column="1" x:Name="OpenModeCombo" Style="{StaticResource SettingControl}"
                                                      SelectionChanged="OpenModeCombo_SelectionChanged">
                                                <ComboBoxItem Content="Double-click" />
                                                <ComboBoxItem Content="Single-click" />
                                            </ComboBox>
                                        </Grid>
                                        <Grid Style="{StaticResource SettingRow}" ColumnDefinitions="*,Auto">
                                            <TextBlock Text="Show file extensions" VerticalAlignment="Center" />
                                            <ToggleSwitch Grid.Column="1" x:Name="ShowExtensionsSwitch" Toggled="ShowExtensionsSwitch_Toggled" />
                                        </Grid>
                                        <Grid Style="{StaticResource SettingRow}" ColumnDefinitions="*,Auto">
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="Spacebar Peek" />
                                                <TextBlock Text="Press Space in the explorer to preview the selected file (Quick Look)."
                                                           Style="{StaticResource SettingDesc}" />
                                            </StackPanel>
                                            <ToggleSwitch Grid.Column="1" x:Name="PeekSwitch" Toggled="PeekSwitch_Toggled" />
                                        </Grid>
                                        <Grid Style="{StaticResource SettingRow}" ColumnDefinitions="*,Auto">
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="Reuse one window" />
                                                <TextBlock Text="Open files from the shell in this window instead of a new one."
                                                           Style="{StaticResource SettingDesc}" />
                                            </StackPanel>
                                            <ToggleSwitch Grid.Column="1" x:Name="SingleInstanceSwitch" Toggled="SingleInstanceSwitch_Toggled" />
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- Photos & videos -->
                            <StackPanel Spacing="8">
                                <TextBlock Text="PHOTOS &amp; VIDEOS" Style="{StaticResource SettingSectionHeader}" />
                                <Border Style="{StaticResource SettingCard}">
                                    <StackPanel Spacing="16">
                                        <Grid Style="{StaticResource SettingRow}" ColumnDefinitions="*,Auto">
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="Open in a new window" />
                                                <TextBlock Text="Opening a photo or video launches a separate Galileo window instead of the in-app viewer."
                                                           Style="{StaticResource SettingDesc}" />
                                            </StackPanel>
                                            <ToggleSwitch Grid.Column="1" x:Name="AlwaysNewWindowSwitch" Toggled="AlwaysNewWindowSwitch_Toggled" />
                                        </Grid>
                                        <Grid Style="{StaticResource SettingRow}" ColumnDefinitions="*,Auto">
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="Close button returns to files" />
                                                <TextBlock Text="While viewing a single photo or video, the window's X goes back to the explorer instead of quitting Galileo."
                                                           Style="{StaticResource SettingDesc}" />
                                            </StackPanel>
                                            <ToggleSwitch Grid.Column="1" x:Name="CloseToBackSwitch" Toggled="CloseToBackSwitch_Toggled" />
                                        </Grid>
                                        <Grid Style="{StaticResource SettingRow}" ColumnDefinitions="*,Auto">
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="Start videos muted" />
                                                <TextBlock Text="New videos begin with their sound muted."
                                                           Style="{StaticResource SettingDesc}" />
                                            </StackPanel>
                                            <ToggleSwitch Grid.Column="1" x:Name="StartMutedSwitch" Toggled="StartMutedSwitch_Toggled" />
                                        </Grid>
                                        <Grid Style="{StaticResource SettingRow}" ColumnDefinitions="*,Auto">
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="Show album art for audio" />
                                                <TextBlock Text="Display embedded cover art when playing audio files."
                                                           Style="{StaticResource SettingDesc}" />
                                            </StackPanel>
                                            <ToggleSwitch Grid.Column="1" x:Name="AlbumArtSwitch" Toggled="AlbumArtSwitch_Toggled" />
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- Slideshow -->
                            <StackPanel Spacing="8">
                                <TextBlock Text="SLIDESHOW" Style="{StaticResource SettingSectionHeader}" />
                                <Border Style="{StaticResource SettingCard}">
                                    <StackPanel Spacing="16">
                                        <StackPanel Spacing="6">
                                            <Grid Style="{StaticResource SettingRow}" ColumnDefinitions="*,Auto">
                                                <TextBlock Text="Seconds per photo" VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="1" x:Name="SlideshowSecondsValue" Text="4s" VerticalAlignment="Center" Opacity="0.8" />
                                            </Grid>
                                            <Slider x:Name="SlideshowSecondsSlider" Minimum="2" Maximum="30" StepFrequency="1"
                                                    ValueChanged="SlideshowSecondsSlider_ValueChanged" />
                                        </StackPanel>
                                        <Grid Style="{StaticResource SettingRow}" ColumnDefinitions="*,Auto">
                                            <TextBlock Text="Shuffle" VerticalAlignment="Center" />
                                            <ToggleSwitch Grid.Column="1" x:Name="ShuffleSwitch" Toggled="ShuffleSwitch_Toggled" />
                                        </Grid>
                                        <Grid Style="{StaticResource SettingRow}" ColumnDefinitions="*,Auto">
                                            <TextBlock Text="Loop" VerticalAlignment="Center" />
                                            <ToggleSwitch Grid.Column="1" x:Name="LoopSwitch" Toggled="LoopSwitch_Toggled" />
                                        </Grid>
                                        <Grid Style="{StaticResource SettingRow}" ColumnDefinitions="*,Auto">
                                            <TextBlock Text="Transition" VerticalAlignment="Center" />
                                            <ComboBox Grid.Column="1" x:Name="TransitionCombo" Style="{StaticResource SettingControl}"
                                                      SelectionChanged="TransitionCombo_SelectionChanged">
                                                <ComboBoxItem Content="None" />
                                                <ComboBoxItem Content="Crossfade" />
                                                <ComboBoxItem Content="Ken Burns" />
                                            </ComboBox>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- Collage -->
                            <StackPanel Spacing="8">
                                <TextBlock Text="COLLAGE" Style="{StaticResource SettingSectionHeader}" />
                                <Border Style="{StaticResource SettingCard}">
                                    <Grid Style="{StaticResource SettingRow}" ColumnDefinitions="*,Auto">
                                        <TextBlock Text="Default layout" VerticalAlignment="Center" />
                                        <ComboBox Grid.Column="1" x:Name="CollageLayoutCombo" Style="{StaticResource SettingControl}"
                                                  SelectionChanged="CollageLayoutCombo_SelectionChanged">
                                            <ComboBoxItem Content="Justified" />
                                            <ComboBoxItem Content="Grid" />
                                            <ComboBoxItem Content="Hero" />
                                        </ComboBox>
                                    </Grid>
                                </Border>
                            </StackPanel>

                            <!-- Privacy -->
                            <StackPanel Spacing="8">
                                <TextBlock Text="PRIVACY" Style="{StaticResource SettingSectionHeader}" />
                                <Border Style="{StaticResource SettingCard}">
                                    <StackPanel Spacing="16">
                                        <Grid Style="{StaticResource SettingRow}" ColumnDefinitions="*,Auto">
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="Lock Hidden album" />
                                                <TextBlock Text="Require Windows Hello / PIN to reveal hidden photos and folders."
                                                           Style="{StaticResource SettingDesc}" />
                                            </StackPanel>
                                            <ToggleSwitch Grid.Column="1" x:Name="LockHiddenSwitch" Toggled="LockHiddenSwitch_Toggled" />
                                        </Grid>
                                        <Grid Style="{StaticResource SettingRow}" ColumnDefinitions="*,Auto">
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="Hide folders when in the background" />
                                                <TextBlock Text="Whenever Galileo loses focus, app-hidden folders collapse to empty again. Click Show app-hidden to reveal them when you return."
                                                           Style="{StaticResource SettingDesc}" />
                                            </StackPanel>
                                            <ToggleSwitch Grid.Column="1" x:Name="HideOnBackgroundSwitch" Toggled="HideOnBackgroundSwitch_Toggled" />
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- Secure vault -->
                            <StackPanel Spacing="8">
                                <TextBlock Text="SECURE VAULT" Style="{StaticResource SettingSectionHeader}" />
                                <Border Style="{StaticResource SettingCard}">
                                    <StackPanel Spacing="16">
                                        <Grid Style="{StaticResource SettingRow}" ColumnDefinitions="*,Auto">
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="Auto-lock when idle" />
                                                <TextBlock Text="Lock an open vault after this much inactivity."
                                                           Style="{StaticResource SettingDesc}" />
                                            </StackPanel>
                                            <ComboBox Grid.Column="1" x:Name="VaultIdleCombo" Style="{StaticResource SettingControl}"
                                                      SelectionChanged="VaultIdleCombo_SelectionChanged">
                                                <ComboBoxItem Content="5 minutes" />
                                                <ComboBoxItem Content="10 minutes" />
                                                <ComboBoxItem Content="15 minutes" />
                                                <ComboBoxItem Content="30 minutes" />
                                                <ComboBoxItem Content="1 hour" />
                                                <ComboBoxItem Content="Never" />
                                            </ComboBox>
                                        </Grid>
                                        <Grid Style="{StaticResource SettingRow}" ColumnDefinitions="*,Auto">
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="Don't auto-lock while sharing" />
                                                <TextBlock Text="Keep the vault unlocked the whole time secure sharing is online, so friends can keep browsing. It still locks once you stop sharing."
                                                           Style="{StaticResource SettingDesc}" />
                                            </StackPanel>
                                            <ToggleSwitch Grid.Column="1" x:Name="NeverLockWhileSharingSwitch" Toggled="NeverLockWhileSharingSwitch_Toggled" />
                                        </Grid>
                                        <Grid Style="{StaticResource SettingRow}" ColumnDefinitions="*,Auto">
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="Default to Windows Hello" />
                                                <TextBlock Text="Pre-check &quot;Also unlock with Windows Hello&quot; when creating a vault."
                                                           Style="{StaticResource SettingDesc}" />
                                            </StackPanel>
                                            <ToggleSwitch Grid.Column="1" x:Name="VaultHelloSwitch" Toggled="VaultHelloSwitch_Toggled" />
                                        </Grid>
                                        <Grid Style="{StaticResource SettingRow}" ColumnDefinitions="*,Auto">
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="Wipe vault after failed unlocks" />
                                                <TextBlock Text="Permanently destroys a vault after too many wrong passphrases. There is no recovery."
                                                           Style="{StaticResource SettingDesc}" />
                                            </StackPanel>
                                            <ToggleSwitch Grid.Column="1" x:Name="VaultWipeSwitch" Toggled="VaultWipeSwitch_Toggled" />
                                        </Grid>
                                        <Grid x:Name="VaultWipeCountRow" Style="{StaticResource SettingRow}" ColumnDefinitions="*,Auto" Visibility="Collapsed">
                                            <TextBlock Text="Wipe after this many attempts" VerticalAlignment="Center" />
                                            <NumberBox Grid.Column="1" x:Name="VaultWipeCountBox" Minimum="1" Maximum="50"
                                                       SpinButtonPlacementMode="Inline" Width="120" VerticalAlignment="Center"
                                                       ValueChanged="VaultWipeCount_ValueChanged" />
                                        </Grid>
                                        <Grid Style="{StaticResource SettingRow}" ColumnDefinitions="*,Auto">
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="Hide vault from the sidebar" />
                                                <TextBlock Text="No vault entry is shown anywhere. Open a vault with Ctrl+Alt+V instead."
                                                           Style="{StaticResource SettingDesc}" />
                                            </StackPanel>
                                            <ToggleSwitch Grid.Column="1" x:Name="HideVaultSwitch" Toggled="HideVaultSwitch_Toggled" />
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- Secure delete -->
                            <StackPanel Spacing="8">
                                <TextBlock Text="SECURE DELETE" Style="{StaticResource SettingSectionHeader}" />
                                <Border Style="{StaticResource SettingCard}">
                                    <StackPanel Spacing="14">
                                        <Grid Style="{StaticResource SettingRow}" ColumnDefinitions="*,Auto">
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="Secure-delete when emptying the Recycle Bin" />
                                                <TextBlock Text="Overwrite files (not just delete them) when you empty the bin. Right-click → Secure delete always overwrites, regardless of this."
                                                           Style="{StaticResource SettingDesc}" />
                                            </StackPanel>
                                            <ToggleSwitch Grid.Column="1" x:Name="SecureEmptySwitch" Toggled="SecureEmptySwitch_Toggled" />
                                        </Grid>
                                        <Grid Style="{StaticResource SettingRow}" ColumnDefinitions="*,Auto">
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="Overwrite method" />
                                                <TextBlock Text="Used by secure delete / shred and by Shift+Delete. More passes are slower."
                                                           Style="{StaticResource SettingDesc}" />
                                            </StackPanel>
                                            <ComboBox Grid.Column="1" x:Name="WipeMethodCombo" Style="{StaticResource SettingControl}"
                                                      SelectionChanged="WipeMethodCombo_SelectionChanged">
                                                <ComboBoxItem Content="Zero (1 pass)" />
                                                <ComboBoxItem Content="Random (1 pass)" />
                                                <ComboBoxItem Content="DoD 5220.22-M (3 passes)" />
                                                <ComboBoxItem Content="DoD ECE (7 passes)" />
                                                <ComboBoxItem Content="Gutmann (35 passes)" />
                                            </ComboBox>
                                        </Grid>
                                        <TextBlock Text="Best-effort: on SSDs/NVMe and copy-on-write drives, wear-leveling and TRIM mean overwriting can't guarantee the original bytes are gone."
                                                   Style="{StaticResource SettingDesc}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- Images -->
                            <StackPanel Spacing="8">
                                <TextBlock Text="IMAGES" Style="{StaticResource SettingSectionHeader}" />
                                <Border Style="{StaticResource SettingCard}">
                                    <Grid Style="{StaticResource SettingRow}" ColumnDefinitions="*,Auto">
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="Move the original to the Recycle Bin after converting" />
                                            <TextBlock Text="When you convert an image (e.g. JPG to PNG), send the source file to the Recycle Bin instead of leaving both copies."
                                                       Style="{StaticResource SettingDesc}" />
                                        </StackPanel>
                                        <ToggleSwitch Grid.Column="1" x:Name="ConvertRemovesOriginalSwitch" Toggled="ConvertRemovesOriginalSwitch_Toggled" />
                                    </Grid>
                                </Border>
                            </StackPanel>

                            <!-- Backup -->
                            <StackPanel Spacing="8">
                                <TextBlock Text="BACKUP" Style="{StaticResource SettingSectionHeader}" />
                                <Border Style="{StaticResource SettingCard}">
                                    <StackPanel Spacing="14">
                                        <Grid Style="{StaticResource SettingRow}" ColumnDefinitions="*,Auto">
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="Google Drive" />
                                                <TextBlock x:Name="BackupStatusText" Text="Not connected" Style="{StaticResource SettingDesc}" />
                                            </StackPanel>
                                            <Button Grid.Column="1" x:Name="BackupConnectBtn" Content="Sign in with Google"
                                                    VerticalAlignment="Center" Click="BackupConnect_Click" />
                                        </Grid>
                                        <StackPanel Orientation="Horizontal" Spacing="10">
                                            <Button x:Name="BackupNowBtn" Content="Back up all vaults now" Click="BackupNow_Click" IsEnabled="False" />
                                            <Button x:Name="BackupRestoreBtn" Content="Restore from Drive…" Click="BackupRestore_Click" IsEnabled="False" />
                                        </StackPanel>
                                        <Grid Style="{StaticResource SettingRow}" ColumnDefinitions="*,Auto">
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="Automatic backup" />
                                                <TextBlock Text="Back up all vaults on a schedule while Galileo is open and signed in."
                                                           Style="{StaticResource SettingDesc}" />
                                            </StackPanel>
                                            <ComboBox Grid.Column="1" x:Name="BackupScheduleCombo" Style="{StaticResource SettingControl}"
                                                      SelectionChanged="BackupScheduleCombo_SelectionChanged">
                                                <ComboBoxItem Content="Off" />
                                                <ComboBoxItem Content="Daily" />
                                                <ComboBoxItem Content="Weekly" />
                                            </ComboBox>
                                        </Grid>
                                        <TextBlock x:Name="LastBackupText" Style="{StaticResource SettingDesc}" />
                                        <TextBlock Text="Only fully-encrypted vault files (obfuscated names) are uploaded. The key never leaves your device."
                                                   Style="{StaticResource SettingDesc}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- Secure sharing -->
                            <StackPanel Spacing="8">
                                <TextBlock Text="SECURE SHARING" Style="{StaticResource SettingSectionHeader}" />
                                <Border Style="{StaticResource SettingCard}">
                                    <StackPanel Spacing="14">
                                        <StackPanel Spacing="6">
                                            <TextBlock Text="Relay server" />
                                            <TextBox x:Name="RelayUrlBox" PlaceholderText="wss://your-relay.example.com"
                                                     TextChanged="RelayUrlBox_TextChanged" />
                                            <TextBlock Text="Address of the rendezvous relay. Files are end-to-end encrypted and never stored on it."
                                                       Style="{StaticResource SettingDesc}" />
                                        </StackPanel>
                                        <Grid Style="{StaticResource SettingRow}" ColumnDefinitions="*,Auto">
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="Disconnect when idle" />
                                                <TextBlock Text="While browsing a friend's shared vault, automatically disconnect after this long with no activity."
                                                           Style="{StaticResource SettingDesc}" />
                                            </StackPanel>
                                            <ComboBox Grid.Column="1" x:Name="RemoteIdleCombo" Style="{StaticResource SettingControl}"
                                                      SelectionChanged="RemoteIdleCombo_SelectionChanged">
                                                <ComboBoxItem Content="Never" />
                                                <ComboBoxItem Content="5 minutes" />
                                                <ComboBoxItem Content="15 minutes" />
                                                <ComboBoxItem Content="30 minutes" />
                                                <ComboBoxItem Content="60 minutes" />
                                            </ComboBox>
                                        </Grid>
                                        <Button x:Name="ManageSharingBtn" Content="Manage secure sharing…" Click="ManageSharing_Click" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- Background -->
                            <StackPanel Spacing="8">
                                <TextBlock Text="BACKGROUND" Style="{StaticResource SettingSectionHeader}" />
                                <Border Style="{StaticResource SettingCard}">
                                    <StackPanel Spacing="14">
                                        <Grid Style="{StaticResource SettingRow}" ColumnDefinitions="*,Auto">
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="Run in the background" />
                                                <TextBlock Text="Closing the window hides Galileo to the system tray instead of quitting, so it keeps hosting your shares. Quit from the tray icon."
                                                           Style="{StaticResource SettingDesc}" />
                                            </StackPanel>
                                            <ToggleSwitch Grid.Column="1" x:Name="RunInBackgroundSwitch" Toggled="RunInBackgroundSwitch_Toggled" />
                                        </Grid>
                                        <Grid Style="{StaticResource SettingRow}" ColumnDefinitions="*,Auto">
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="Start with Windows" />
                                                <TextBlock Text="Launch Galileo minimized to the tray when you sign in (also turns on Run in the background)."
                                                           Style="{StaticResource SettingDesc}" />
                                            </StackPanel>
                                            <ToggleSwitch Grid.Column="1" x:Name="StartWithWindowsSwitch" Toggled="StartWithWindowsSwitch_Toggled" />
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- Developer -->
                            <StackPanel Spacing="8">
                                <TextBlock Text="DEVELOPER" Style="{StaticResource SettingSectionHeader}" />
                                <Border Style="{StaticResource SettingCard}">
                                    <Grid Style="{StaticResource SettingRow}" ColumnDefinitions="*,Auto">
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="Developer Mode" />
                                            <TextBlock Text="Show an embedded terminal pane (cmd / PowerShell / WSL) beside the explorer."
                                                       Style="{StaticResource SettingDesc}" />
                                        </StackPanel>
                                        <ToggleSwitch Grid.Column="1" x:Name="DeveloperModeSwitch" Toggled="DeveloperModeSwitch_Toggled" />
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Footer: explicit Save / Cancel -->
                    <Grid Grid.Row="2" Padding="24,14,24,18" BorderThickness="0,1,0,0"
                          BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
                            <Button Content="Cancel" Click="SettingsCancel_Click" MinWidth="96" />
                            <Button Content="Save" Click="SettingsSave_Click" Style="{StaticResource AccentButtonStyle}" MinWidth="96" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- ===================== Peek (Quick Look) overlay ===================== -->
        <Grid x:Name="PeekOverlay" Visibility="Collapsed" Background="#B0000000"
              IsTabStop="True" Tapped="PeekScrim_Tapped">
            <Border x:Name="PeekCard" MaxWidth="1100" MaxHeight="840" Margin="64"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="{ThemeResource SolidBackgroundFillColorBaseBrush}" CornerRadius="14"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    Tapped="PeekCard_Tapped">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Grid Grid.Row="0" Padding="16,10" ColumnDefinitions="*,Auto"
                          Background="{ThemeResource LayerFillColorAltBrush}">
                        <TextBlock x:Name="PeekTitle" VerticalAlignment="Center" FontWeight="SemiBold"
                                   FontSize="14" TextTrimming="CharacterEllipsis" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="2">
                            <Button x:Name="PeekOpenBtn" Style="{StaticResource GlyphButton}" Click="PeekOpen_Click"
                                    ToolTipService.ToolTip="Open (Enter)">
                                <FontIcon Glyph="&#xE8E5;" FontFamily="Segoe Fluent Icons" FontSize="14" />
                            </Button>
                            <Button Style="{StaticResource GlyphButton}" Click="PeekClose_Click"
                                    ToolTipService.ToolTip="Close (Space / Esc)">
                                <FontIcon Glyph="&#xE8BB;" FontFamily="Segoe Fluent Icons" FontSize="14" />
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- Content: exactly one child is shown per file type -->
                    <Grid Grid.Row="1" Background="#FF101013" MinWidth="520" MinHeight="340">
                        <Image x:Name="PeekImage" Stretch="Uniform" Margin="10" Visibility="Collapsed" />
                        <MediaPlayerElement x:Name="PeekVideo" Visibility="Collapsed"
                                            AreTransportControlsEnabled="True" AutoPlay="True" Stretch="Uniform" />
                        <ScrollViewer x:Name="PeekTextScroller" Visibility="Collapsed"
                                      Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                                      VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Padding="16">
                            <TextBlock x:Name="PeekText" FontFamily="Consolas" FontSize="13"
                                       IsTextSelectionEnabled="True" TextWrapping="NoWrap" />
                        </ScrollViewer>
                        <StackPanel x:Name="PeekFallback" Visibility="Collapsed" Spacing="14"
                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Image x:Name="PeekFallbackImage" Width="128" Height="128" HorizontalAlignment="Center" />
                            <TextBlock x:Name="PeekFallbackText" Opacity="0.85" FontSize="13" Foreground="White"
                                       HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>

                    <!-- Footer: type · size · modified -->
                    <Border Grid.Row="2" Padding="16,8" Background="{ThemeResource LayerFillColorAltBrush}">
                        <TextBlock x:Name="PeekInfo" FontSize="12" Opacity="0.75" TextTrimming="CharacterEllipsis" />
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- ===================== Title bar (drag region) ===================== -->
        <!-- Symmetric columns keep ModeLabel centered on the window while reserving room for the
             brand (left) and the system caption buttons (right) so they never overlap. -->
        <Grid x:Name="AppTitleBar" Height="40" VerticalAlignment="Top" Background="Transparent"
              ColumnDefinitions="160,*,160">
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="14,0,0,0"
                        HorizontalAlignment="Left" VerticalAlignment="Center">
                <Image x:Name="TitleLogo" Width="20" Height="20" VerticalAlignment="Center" />
                <TextBlock Text="Galileo" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center" />
            </StackPanel>
            <TextBlock x:Name="ModeLabel" Grid.Column="1" Text="" Opacity="0.75" FontSize="13"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis" />
        </Grid>

        <!-- Subtle status text — left-aligned but width-bounded + ellipsized so long messages
             (e.g. a wipe/transfer with a long filename) never spill across the window or sidebar. -->
        <TextBlock x:Name="StatusText" Text="Ready" FontSize="12" Opacity="0.55"
                   HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="16,0,16,8"
                   MaxWidth="460" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"
                   IsHitTestVisible="False" />

        <!-- ===================== File-transfer progress (Apple-style floating card) ===================== -->
        <Border x:Name="TransferPanel" Visibility="Collapsed" Opacity="0"
                HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,46" Width="404"
                Background="{ThemeResource AcrylicInAppFillColorDefaultBrush}"
                BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="1"
                CornerRadius="16" Padding="18,15,16,16" Translation="0,0,40">
            <Border.Shadow>
                <ThemeShadow />
            </Border.Shadow>
            <Border.RenderTransform>
                <TranslateTransform x:Name="TransferPanelShift" Y="24" />
            </Border.RenderTransform>
            <StackPanel Spacing="12">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="TransferTitle" Text="Copying" FontSize="14" FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock x:Name="TransferFile" Text="" FontSize="12" Opacity="0.6"
                                   TextTrimming="CharacterEllipsis" Margin="0,1,0,0" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                        <Button x:Name="TransferPauseBtn" Click="TransferPause_Click"
                                Width="32" Height="32" CornerRadius="16" Padding="0" VerticalAlignment="Center"
                                ToolTipService.ToolTip="Pause">
                            <FontIcon x:Name="TransferPauseIcon" Glyph="&#xE769;" FontFamily="Segoe Fluent Icons" FontSize="13" />
                        </Button>
                        <Button x:Name="TransferHideBtn" Click="TransferHide_Click"
                                Width="32" Height="32" CornerRadius="16" Padding="0" VerticalAlignment="Center"
                                ToolTipService.ToolTip="Hide (keeps running)">
                            <FontIcon Glyph="&#xE921;" FontFamily="Segoe Fluent Icons" FontSize="12" />
                        </Button>
                        <Button x:Name="TransferCancelBtn" Click="TransferCancel_Click"
                                Width="32" Height="32" CornerRadius="16" Padding="0" VerticalAlignment="Center"
                                ToolTipService.ToolTip="Cancel">
                            <FontIcon Glyph="&#xE711;" FontFamily="Segoe Fluent Icons" FontSize="12" />
                        </Button>
                    </StackPanel>
                </Grid>
                <Grid x:Name="TransferBarTrack" Height="6" CornerRadius="3" Background="#30808080"
                      SizeChanged="TransferBarTrack_SizeChanged">
                    <Border x:Name="TransferBarFill" HorizontalAlignment="Left" Width="0" CornerRadius="3">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#6EA8FF" Offset="0" />
                                <GradientStop Color="#5A8AE0" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                </Grid>
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock x:Name="TransferStats" Text="" FontSize="11" Opacity="0.6" VerticalAlignment="Center" />
                    <TextBlock x:Name="TransferEta" Grid.Column="1" Text="" FontSize="11" Opacity="0.6"
                               VerticalAlignment="Center" TextAlignment="Right" />
                </Grid>
            </StackPanel>
        </Border>

        <!-- Camera-style edge flash to confirm a screenshot was captured (animated in code). -->
        <Border x:Name="ScreenshotFlash" Visibility="Collapsed" Opacity="0" IsHitTestVisible="False"
                BorderBrush="White" BorderThickness="14" />
    </Grid>
</Window>
